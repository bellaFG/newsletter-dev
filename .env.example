# ── Supabase ──────────────────────────────────────────────────────────────────
# URL da instancia Supabase (encontre em: Settings > API)
SUPABASE_URL=

# Chave anonima (anon key) — usada no client publico (paginas server-side)
SUPABASE_ANON_KEY=

# Chave service role — acesso total, bypassa RLS. NUNCA expor no client.
SUPABASE_SERVICE_ROLE_KEY=

# Migrations agora usam o Supabase CLI oficial (`supabase link` + `supabase db push`).
# Nao coloque credenciais de banco aqui; o CLI cuida disso separadamente.

# ── Brevo (envio de emails) ─────────────────────────────────────────────────
BREVO_API_KEY=

# ── Alertas operacionais ─────────────────────────────────────────────────────
# Webhook do Discord para avisos de atraso/falha da newsletter
DISCORD_ALERT_WEBHOOK_URL=

# ── Seguranca da API interna ─────────────────────────────────────────────────
# Token Bearer usado para autenticar chamadas ao endpoint /api/send-newsletter
NEWSLETTER_API_SECRET=

# ── IA — pipeline Python (triagem + leitura + curadoria editorial) ──────────
OPENAI_API_KEY=
OPENAI_CURATION_TRIAGE_MODEL=gpt-5.4-nano
OPENAI_CURATION_TRIAGE_REASONING=low
OPENAI_CURATION_EDITOR_MODEL=gpt-5.4
OPENAI_CURATION_EDITOR_REASONING=medium
OPENAI_CURATION_WRITER_MODEL=gpt-5.4-mini
OPENAI_CURATION_WRITER_REASONING=low
OPENAI_CURATION_SOURCE_TEXT_MAX_CHARS=6000
OPENAI_CURATION_MAX_RETRIES=3

# ── URL do site (usado pelo pipeline Python para chamar a API) ───────────────
# Em desenvolvimento: http://localhost:4321
# Em producao: https://devpulse.com.br (ou URL do Vercel)
SITE_URL=http://localhost:4321
