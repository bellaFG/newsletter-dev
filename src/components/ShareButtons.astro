---
interface Props {
  title: string
  url: string
}

const { title, url } = Astro.props
const encodedUrl = encodeURIComponent(url)
const encodedTitle = encodeURIComponent(title)
const encodedLinkedInText = encodeURIComponent(`${title}\n\n${url}`)
---

<div
  class="flex flex-wrap items-center gap-2"
  data-share-root
>
  <button
    type="button"
    data-share-copy
    data-share-url={url}
    class="inline-flex items-center gap-2 border border-link/30 px-3 py-1.5 font-mono text-[0.55rem] font-bold uppercase tracking-[0.2em] text-link transition-colors hover:border-link hover:bg-link hover:text-white motion-reduce:transition-none"
  >
    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="9" y="9" width="13" height="13" rx="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    Copiar link
  </button>

  <a
    href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 border border-foreground/15 px-3 py-1.5 font-mono text-[0.55rem] uppercase tracking-[0.2em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground motion-reduce:transition-none"
  >
    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.9 2H22l-6.77 7.74L23.2 22h-6.26l-4.9-7.43L5.53 22H2.4l7.23-8.27L1.92 2h6.42l4.43 6.73L18.9 2Z" />
    </svg>
    X
  </a>

  <a
    href={`https://www.linkedin.com/feed/?shareActive=true&text=${encodedLinkedInText}`}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 border border-foreground/15 px-3 py-1.5 font-mono text-[0.55rem] uppercase tracking-[0.2em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground motion-reduce:transition-none"
  >
    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M6.94 8.5A1.56 1.56 0 1 0 6.9 5.4a1.56 1.56 0 0 0 .04 3.1ZM5.5 9.75h2.9V18H5.5V9.75Zm4.7 0h2.78v1.12h.04c.39-.73 1.33-1.5 2.75-1.5 2.95 0 3.49 1.82 3.49 4.18V18h-2.9v-3.92c0-.94-.02-2.16-1.41-2.16-1.41 0-1.62 1.03-1.62 2.09V18h-2.9V9.75Z" />
    </svg>
    LinkedIn
  </a>

  <p class="sr-only" aria-live="polite" data-share-feedback></p>
</div>

<script>
  function initShare(root: Element) {
    if (!(root instanceof HTMLElement) || root.dataset.shareInit === '1') return
    root.dataset.shareInit = '1'

    const copyButton = root.querySelector('[data-share-copy]')
    const feedback = root.querySelector('[data-share-feedback]')

    if (!(copyButton instanceof HTMLButtonElement)) return

    copyButton.addEventListener('click', async () => {
      const url = copyButton.dataset.shareUrl
      if (!url) return

      try {
        await navigator.clipboard.writeText(url)
        if (feedback instanceof HTMLElement) {
          feedback.textContent = 'Link copiado.'
        }
      } catch {
        if (feedback instanceof HTMLElement) {
          feedback.textContent = 'Não foi possível copiar o link.'
        }
      }
    })
  }

  function bindShareButtons() {
    document.querySelectorAll('[data-share-root]').forEach((root) => {
      initShare(root)
    })
  }

  bindShareButtons()
  document.addEventListener('astro:page-load', bindShareButtons)
</script>
