---
/**
 * Barra de navegacao por categorias.
 * Modo "pills" (pagina de categoria) ou "links" (homepage).
 */
import { CATEGORY_ORDER, CATEGORY_SLUGS } from '@/lib/articles'
import type { ArticleCategory } from '@/lib/types'

interface Props {
  mode?: 'links' | 'pills'
  active?: ArticleCategory
}

const { mode = 'links', active } = Astro.props
---

{mode === 'pills' ? (
  <nav class="mb-8 overflow-x-auto -mx-6 px-6 scrollbar-thin">
    <div class="flex gap-2 min-w-max pb-1">
      {CATEGORY_ORDER.map((cat) => {
        const slug = CATEGORY_SLUGS[cat]
        const isActive = cat === active
        return (
          <a
            href={`/categoria/${slug}`}
            class:list={[
              'font-mono text-[0.5rem] tracking-widest uppercase px-3 py-1.5 border whitespace-nowrap transition-colors shrink-0',
              isActive
                ? 'bg-foreground text-background border-foreground font-bold'
                : 'border-foreground/20 text-muted-foreground hover:border-foreground hover:text-foreground',
            ]}
          >
            {cat}
          </a>
        )
      })}
    </div>
  </nav>
) : (
  <nav class="overflow-x-auto sm:overflow-x-visible -mx-6 px-6 sm:mx-0 sm:px-0 py-3 scrollbar-thin">
    <div class="flex sm:flex-wrap sm:justify-center gap-x-4 gap-y-1.5 min-w-max sm:min-w-0 font-mono text-[0.6rem] tracking-widest uppercase pb-1 sm:pb-0">
      {CATEGORY_ORDER.map((cat, i) => (
        <>
          {i > 0 && <span class="text-foreground/20 select-none hidden sm:inline" aria-hidden="true">|</span>}
          <a
            href={`/categoria/${CATEGORY_SLUGS[cat]}`}
            class="text-muted-foreground hover:text-link transition-colors whitespace-nowrap shrink-0"
          >
            {cat}
          </a>
        </>
      ))}
    </div>
  </nav>
)}
