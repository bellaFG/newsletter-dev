---
import { CATEGORY_ORDER, CATEGORY_SLUGS } from '@/lib/articles'
import ThemeToggle from '@/components/ThemeToggle.astro'
import { SITE_NAME } from '@/lib/config'

const pathname = Astro.url.pathname
const initialSearchQuery = Astro.url.searchParams.get('q')?.trim() ?? ''
const isSearchOpen = initialSearchQuery.length > 0
const showNavSearch = pathname !== '/'

const activeSection =
  pathname === '/'
    ? 'home'
    : pathname.startsWith('/archive') || pathname.startsWith('/edicao/')
      ? 'editions'
      : pathname.startsWith('/articles')
        ? 'articles'
        : pathname.startsWith('/categoria/')
          ? 'categories'
          : ''

const navLinkClasses = (isActive: boolean) =>
  [
    'whitespace-nowrap border-b pb-1 transition-colors',
    isActive
      ? 'border-link text-link'
      : 'border-transparent text-muted-foreground hover:border-foreground/20 hover:text-foreground',
  ].join(' ')

const navActionClasses = [
  'site-search-toggle whitespace-nowrap border-b border-transparent bg-transparent pb-1 font-mono text-[0.55rem] uppercase tracking-[0.22em] text-muted-foreground transition-colors hover:border-foreground/20 hover:text-foreground md:text-[0.58rem] md:tracking-[0.24em]',
].join(' ')

const categories = CATEGORY_ORDER.map((category) => ({
  label: category,
  href: `/categoria/${CATEGORY_SLUGS[category]}`,
}))
---

<header
  data-site-header
  class="sticky top-0 z-40 border-b border-foreground/10 bg-background/92 backdrop-blur supports-[backdrop-filter]:bg-background/85"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-10">
    <div class="flex min-h-12 items-center gap-3 sm:min-h-14 sm:gap-4">
      <a
        href="/"
        class="shrink-0 font-serif text-[0.95rem] font-black uppercase tracking-tight transition-opacity hover:opacity-60 sm:text-sm"
      >
        {SITE_NAME}
      </a>

      <nav
        aria-label="Navegação principal"
        class="ml-4 hidden flex-1 items-center justify-center gap-5 font-mono text-[0.58rem] uppercase tracking-[0.24em] md:flex"
      >
        <a href="/" class={navLinkClasses(activeSection === 'home')}>Início</a>
        <a href="/archive" class={navLinkClasses(activeSection === 'editions')}>Edições</a>
        <a href="/articles" class={navLinkClasses(activeSection === 'articles')}>Artigos</a>

        <details class="group relative">
          <summary
            class:list={[
              'flex cursor-pointer list-none items-center gap-1 border-b pb-1 transition-colors',
              activeSection === 'categories'
                ? 'border-link text-link'
                : 'border-transparent text-muted-foreground hover:border-foreground/20 hover:text-foreground',
            ]}
          >
            Categorias
            <svg
              class="h-3 w-3 transition-transform group-open:rotate-180"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path d="m4 6 4 4 4-4" />
            </svg>
          </summary>

          <div class="absolute left-1/2 top-full z-50 mt-3 hidden w-72 -translate-x-1/2 border border-foreground/15 bg-background p-4 shadow-[0_18px_40px_rgba(15,23,42,0.08)] group-open:block">
            <div class="grid grid-cols-2 gap-2">
              {categories.map((category) => (
                <a
                  href={category.href}
                  class="border border-transparent px-2 py-2 font-mono text-[0.52rem] uppercase tracking-[0.18em] text-muted-foreground transition-colors hover:border-foreground/10 hover:text-link"
                >
                  {category.label}
                </a>
              ))}
            </div>
          </div>
        </details>

        {showNavSearch && (
          <button
            type="button"
            data-search-toggle
            data-search-open={isSearchOpen ? 'true' : 'false'}
            aria-controls="site-search-panel"
            aria-expanded={isSearchOpen ? 'true' : 'false'}
            class={navActionClasses}
          >
            Buscar
          </button>
        )}
      </nav>

      <div class="ml-auto flex shrink-0 items-center gap-2">
        <ThemeToggle />

        <button
          id="subscribe-open-btn"
          data-subscribe-open
          class="inline-flex h-8 items-center border border-link px-2.5 font-mono text-[0.52rem] font-bold uppercase tracking-[0.18em] text-link transition-colors hover:bg-link hover:text-background sm:px-3 sm:text-[0.55rem] sm:tracking-[0.22em]"
        >
          Assinar
        </button>
      </div>
    </div>

    <div class="border-t border-foreground/10 md:hidden">
      <div class="flex items-center justify-between gap-3 py-3">
        <nav
          aria-label="Navegação principal"
          class="scrollbar-thin flex min-w-0 flex-1 items-center gap-3 overflow-x-auto whitespace-nowrap font-mono text-[0.55rem] uppercase tracking-[0.22em] sm:gap-4"
        >
          <a href="/" class={navLinkClasses(activeSection === 'home')}>Início</a>
          <a href="/archive" class={navLinkClasses(activeSection === 'editions')}>Edições</a>
          <a href="/articles" class={navLinkClasses(activeSection === 'articles')}>Artigos</a>
          {showNavSearch && (
            <button
              type="button"
              data-search-toggle
              data-search-open={isSearchOpen ? 'true' : 'false'}
              aria-controls="site-search-panel"
              aria-expanded={isSearchOpen ? 'true' : 'false'}
              class={navActionClasses}
            >
              Buscar
            </button>
          )}
        </nav>

        <details class="relative shrink-0">
          <summary class="flex cursor-pointer list-none items-center gap-1 font-mono text-[0.55rem] uppercase tracking-[0.22em] text-muted-foreground transition-colors hover:text-foreground">
            Categorias
            <svg
              class="h-3 w-3"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path d="m4 6 4 4 4-4" />
            </svg>
          </summary>

          <div class="absolute right-0 top-full z-50 mt-3 w-64 border border-foreground/15 bg-background p-4 shadow-[0_18px_40px_rgba(15,23,42,0.08)]">
            <div class="grid gap-2">
              {categories.map((category) => (
                <a
                  href={category.href}
                  class="border border-transparent px-2 py-2 font-mono text-[0.52rem] uppercase tracking-[0.18em] text-muted-foreground transition-colors hover:border-foreground/10 hover:text-link"
                >
                  {category.label}
                </a>
              ))}
            </div>
          </div>
        </details>
      </div>
    </div>

    {showNavSearch && (
      <div
        id="site-search-panel"
        data-search-panel
        data-open={isSearchOpen ? 'true' : 'false'}
        aria-hidden={isSearchOpen ? 'false' : 'true'}
        class="site-search-panel border-t border-foreground/10"
      >
        <div class="site-search-panel__inner">
          <div class="py-4 sm:py-5">
            <form
              method="get"
              action="/"
              class="flex flex-col gap-3 lg:flex-row lg:items-center lg:gap-4"
              data-nav-search-form
              data-astro-reload
            >
              <label class="relative flex-1">
                <span class="sr-only">Buscar no acervo</span>
                <svg
                  class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <input
                  type="search"
                  name="q"
                  value={initialSearchQuery}
                  autocomplete="off"
                  enterkeyhint="search"
                  placeholder="Busque temas, fontes ou edições"
                  class="h-9 w-full border border-foreground/20 bg-background px-4 pl-10 text-sm font-mono placeholder:text-muted-foreground transition-colors focus:border-link focus:outline-none"
                  data-nav-search-input
                />
              </label>

              <div class="flex items-center gap-2">
                <button
                  type="submit"
                  class="inline-flex h-9 items-center justify-center border border-link px-4 font-mono text-[0.56rem] font-bold uppercase tracking-[0.22em] text-link transition-colors hover:bg-link hover:text-white"
                >
                  Buscar
                </button>
              </div>
            </form>

            <div class="mt-3 flex flex-wrap items-center justify-end gap-2">
              <p
                class="hidden font-mono text-[0.55rem] uppercase tracking-[0.2em] text-link"
                data-nav-search-meta
              ></p>
            </div>

            <div
              class="scrollbar-thin mt-4 hidden max-h-[min(60vh,34rem)] space-y-3 overflow-y-auto pr-1"
              aria-live="polite"
              data-nav-search-results
            ></div>
          </div>
        </div>
      </div>
    )}
  </div>
</header>

<style>
  .site-search-toggle[data-search-open='true'] {
    border-color: var(--link);
    color: var(--link);
  }

  .site-search-panel {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-10px);
    transition:
      grid-template-rows 260ms ease,
      opacity 180ms ease,
      transform 260ms ease;
  }

  .site-search-panel[data-open='true'] {
    grid-template-rows: 1fr;
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .site-search-panel__inner {
    overflow: hidden;
  }
</style>
