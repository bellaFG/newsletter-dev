---
/**
 * Masthead compacto usado nas paginas internas (edicao, arquivo, artigo).
 * Exibe: lado esquerdo | centro (nome do site) | lado direito.
 */
import { SITE_NAME } from '@/lib/config'

interface Props {
  left?: string
  right?: string
  leftHref?: string
}

const { left, right, leftHref } = Astro.props
---

<header class="border-b border-foreground/30 pb-4 mb-8">
  <div class="flex flex-col sm:grid sm:grid-cols-3 items-center sm:items-baseline gap-1 sm:gap-0">
    <p class="order-2 font-mono text-[0.6rem] uppercase tracking-[0.2em] text-link text-center sm:order-1 sm:text-left sm:text-[0.65rem] sm:tracking-widest">
      {leftHref ? (
        <a href={leftHref} class="hover:opacity-70 transition-colors">{left}</a>
      ) : (
        left
      )}
    </p>
    <a
      href="/"
      class="font-serif text-2xl font-black tracking-tighter uppercase hover:opacity-60 transition-opacity text-center order-1 sm:order-2"
    >
      {SITE_NAME.toUpperCase()}
    </a>
    <span class="order-3 font-mono text-[0.6rem] uppercase tracking-[0.2em] text-link text-center sm:text-right sm:text-[0.65rem] sm:tracking-widest">
      {right}
    </span>
  </div>
</header>
