---
/**
 * Card de artigo usado na grid da homepage e em listagens.
 */
import type { Article } from '@/lib/types'
import { formatRelativeTime } from '@/lib/date'

interface Props {
  article: Article
  href: string
}

const { article, href } = Astro.props
---

<a
  href={href}
  class="block border border-foreground/10 p-5 hover:border-link/40 transition-colors group"
  data-title={(article.title_ptbr ?? article.title).toLowerCase()}
  data-summary={(article.summary_ptbr ?? '').toLowerCase()}
>
  <h3 class="font-serif text-lg font-bold leading-snug mb-2 group-hover:text-link transition-colors">
    {article.title_ptbr ?? article.title}
  </h3>
  <p class="text-sm text-foreground/60 line-clamp-2 leading-relaxed mb-3">
    {article.summary_ptbr}
  </p>
  <div class="flex items-center justify-between font-mono text-[0.5rem] text-muted-foreground">
    <span class="text-link">{article.source}</span>
    <div class="flex items-center gap-2">
      {article.reading_time_min && <span>{article.reading_time_min} min</span>}
      <span class="text-link">{formatRelativeTime(article.created_at)}</span>
    </div>
  </div>
</a>
