---
import { getAnnouncementDismissStorageKey, type SiteAnnouncement } from '@/lib/announcements'

interface Props {
  announcement: SiteAnnouncement
  compact?: boolean
}

const { announcement, compact = false } = Astro.props

const toneClasses = {
  info: {
    wrapper: 'border-link/30 bg-link/5',
    eyebrow: 'text-link',
    cta: 'border-link text-link hover:bg-link hover:text-white',
  },
  warning: {
    wrapper: 'border-amber-500/40 bg-amber-500/10',
    eyebrow: 'text-amber-700 dark:text-amber-300',
    cta: 'border-amber-600 text-amber-700 hover:bg-amber-600 hover:text-white dark:text-amber-300 dark:border-amber-400',
  },
  success: {
    wrapper: 'border-emerald-500/35 bg-emerald-500/10',
    eyebrow: 'text-emerald-700 dark:text-emerald-300',
    cta: 'border-emerald-600 text-emerald-700 hover:bg-emerald-600 hover:text-white dark:text-emerald-300 dark:border-emerald-400',
  },
} as const

const tone = toneClasses[announcement.tone]
const dismissStorageKey =
  announcement.dismissible === false ? null : getAnnouncementDismissStorageKey(announcement)
const eyebrowLabel = announcement.eyebrow ?? 'Comunicado'
---

<section class:list={[
  'border-2',
  tone.wrapper,
  compact ? 'p-4 sm:p-5' : 'p-6 sm:p-7',
]} data-announcement-root data-announcement-dismiss-key={dismissStorageKey ?? undefined}>
  <div class="mb-3 flex items-start justify-between gap-3">
    <p class:list={[
      'font-mono font-bold uppercase',
      compact ? 'text-[0.5rem] tracking-[0.22em]' : 'text-[0.55rem] tracking-[0.25em]',
      tone.eyebrow,
    ]}>
      {eyebrowLabel}
    </p>

    {dismissStorageKey && (
      <button
        type="button"
        data-announcement-dismiss
        class="shrink-0 font-mono text-sm leading-none text-muted-foreground transition-colors hover:text-foreground motion-reduce:transition-none"
        aria-label="Fechar mural de recados"
      >
        &times;
      </button>
    )}
  </div>

  <div class:list={[
    'flex flex-col gap-4',
    compact ? 'lg:flex-row lg:items-center lg:justify-between' : 'sm:flex-row sm:items-end sm:justify-between',
  ]}>
    <div class={compact ? 'max-w-3xl' : 'max-w-2xl'}>
      <h2 class:list={[
        'font-serif font-black tracking-tight text-foreground',
        compact ? 'mb-1 text-lg sm:text-xl' : 'mb-2 text-2xl',
      ]}>
        {announcement.title}
      </h2>

      <p class:list={[
        'leading-relaxed text-foreground/75',
        compact ? 'text-sm' : 'text-sm',
      ]}>
        {announcement.message}
      </p>

      {announcement.note && (
        <p class:list={[
          'mt-2 font-mono uppercase text-muted-foreground',
          compact ? 'text-[0.6rem] tracking-[0.18em]' : 'text-[0.65rem] tracking-wider',
        ]}>
          {announcement.note}
        </p>
      )}
    </div>

    {announcement.ctaHref && announcement.ctaLabel && (
      <a
        href={announcement.ctaHref}
        class:list={[
          'inline-flex shrink-0 items-center justify-center border-2 px-5 py-2.5 font-mono text-[0.55rem] font-bold uppercase tracking-widest transition-colors motion-reduce:transition-none',
          tone.cta,
        ]}
      >
        {announcement.ctaLabel}
      </a>
    )}
  </div>
</section>

<script>
  function collapseAnnouncementSlot(root: Element) {
    const slot = root.closest('[data-announcement-slot]')
    if (!(slot instanceof HTMLElement)) return

    const hasVisibleAnnouncements = Array.from(
      slot.querySelectorAll('[data-announcement-root]'),
    ).some((candidate) => {
      return candidate instanceof HTMLElement && !candidate.hidden
    })

    if (!hasVisibleAnnouncements) {
      slot.hidden = true
    }
  }

  function initAnnouncement(root: Element) {
    if (!(root instanceof HTMLElement)) return

    const dismissKey = root.dataset.announcementDismissKey
    if (!dismissKey) return

    const dismissButton = root.querySelector('[data-announcement-dismiss]')

    const hideAnnouncement = () => {
      root.hidden = true
      collapseAnnouncementSlot(root)
    }

    try {
      if (window.localStorage.getItem(dismissKey) === '1') {
        hideAnnouncement()
        return
      }
    } catch {}

    if (!(dismissButton instanceof HTMLButtonElement)) return

    dismissButton.addEventListener('click', () => {
      try {
        window.localStorage.setItem(dismissKey, '1')
      } catch {}

      hideAnnouncement()
    })
  }

  function bindAnnouncements() {
    document.querySelectorAll('[data-announcement-root]').forEach((root) => {
      initAnnouncement(root)
    })
  }

  bindAnnouncements()
  document.addEventListener('astro:page-load', bindAnnouncements)
</script>
