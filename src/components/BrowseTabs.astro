---
interface Props {
  active: 'editions' | 'articles'
}

const { active } = Astro.props
const items = [
  { key: 'editions', label: 'Edições', href: '/archive' },
  { key: 'articles', label: 'Artigos', href: '/articles' },
] as const
---

<nav aria-label="Formatos do acervo" class="mb-8 border-y border-foreground/15 py-3">
  <div class="flex items-center justify-center gap-2 font-mono text-[0.58rem] uppercase tracking-[0.24em]">
    {items.map((item) => (
      <a
        href={item.href}
        class:list={[
          'border px-4 py-2 transition-colors',
          item.key === active
            ? 'border-link bg-link/5 text-link'
            : 'border-foreground/10 text-muted-foreground hover:border-foreground/20 hover:text-foreground',
        ]}
        aria-current={item.key === active ? 'page' : undefined}
      >
        {item.label}
      </a>
    ))}
  </div>
</nav>
