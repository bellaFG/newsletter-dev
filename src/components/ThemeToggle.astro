<button
  id="theme-toggle"
  type="button"
  class="inline-flex h-9 w-9 items-center justify-center border border-foreground/15 text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
  aria-label="Ativar tema escuro"
>
  <svg
    data-theme-icon="moon"
    class="h-4 w-4"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="1.8"
    aria-hidden="true"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8Z" />
  </svg>
  <svg
    data-theme-icon="sun"
    class="hidden h-4 w-4"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="1.8"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2.5M12 19.5V22M4.93 4.93l1.77 1.77M17.3 17.3l1.77 1.77M2 12h2.5M19.5 12H22M4.93 19.07l1.77-1.77M17.3 6.7l1.77-1.77" />
  </svg>
  <span id="theme-label" class="sr-only">Alternar tema</span>
</button>
