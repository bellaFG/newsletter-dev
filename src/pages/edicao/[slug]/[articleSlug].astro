---
import Layout from '@/layouts/Layout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageFooterNav from '@/components/PageFooterNav.astro'
import ReadingTime from '@/components/ReadingTime.astro'
import SectionHeader from '@/components/SectionHeader.astro'
import ShareButtons from '@/components/ShareButtons.astro'
import { getEditionDisplayDate } from '@/lib/editions'
import { supabase } from '@/lib/supabase'
import type { Article, Edition } from '@/lib/types'
import { CATEGORY_SLUGS, getArticleSources, getPrimarySource } from '@/lib/articles'
import { formatMediumDate, formatEditionNumber } from '@/lib/date'
import { normalizePublicSiteUrl, SITE_NAME } from '@/lib/config'
import { readEnv } from '@/lib/env'

const { slug, articleSlug } = Astro.params

const { data: editionData } = await supabase
  .from('editions')
  .select('*')
  .eq('slug', slug!)
  .single()

const edition = editionData as Edition | null
if (!edition || !edition.published_at) return new Response(null, { status: 404 })

const { data: articleData } = await supabase
  .from('articles')
  .select('*')
  .eq('edition_id', edition.id)
  .eq('slug', articleSlug!)
  .single()

const article = articleData as Article | null
if (!article) return new Response(null, { status: 404 })

const { data: relatedData } = await supabase
  .from('articles')
  .select('*')
  .eq('edition_id', edition.id)
  .eq('category', article.category)
  .neq('id', article.id)
  .order('position', { ascending: true })
  .limit(3)

const related = (relatedData ?? []) as Article[]

const categorySlug = CATEGORY_SLUGS[article.category]
const sources = getArticleSources(article)
const primarySource = getPrimarySource(article)
const secondarySources = sources.filter((source) => !source.is_primary)
const siteUrl = normalizePublicSiteUrl(readEnv('SITE_URL'))
const articlePath = `/edicao/${edition.slug}/${article.slug}`
const articleUrl = `${siteUrl}${articlePath}`

function getSourceHost(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, '')
  } catch {
    return 'fonte externa'
  }
}
---

<Layout
  title={`${article.title_ptbr ?? article.title} — ${SITE_NAME}`}
  description={article.summary_ptbr.slice(0, 160)}
  canonicalUrl={articleUrl}
>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">

      <Breadcrumbs
        items={[
          { label: 'Início', href: '/' },
          { label: `Edição #${formatEditionNumber(edition.edition_number)}`, href: `/edicao/${edition.slug}` },
          { label: 'Artigo' },
        ]}
      />

      <article>
        <a
          href={`/categoria/${categorySlug}`}
          class="inline-block font-mono text-[0.5rem] tracking-widest uppercase text-link border border-link/30 px-2 py-0.5 mb-4 hover:bg-link hover:text-white transition-colors"
        >
          {article.category}
        </a>

        <h1 class="font-serif text-3xl sm:text-4xl font-black leading-[1.1] tracking-tight mb-2">
          {article.title_ptbr ?? article.title}
        </h1>
        {article.title_ptbr && article.original_language !== 'pt' && (
          <p class="font-mono text-[0.6rem] text-muted-foreground italic mb-4">
            {article.title}
          </p>
        )}

        <div class="flex flex-wrap items-center gap-2 font-mono text-[0.6rem] text-link mb-8">
          <span class="tracking-widest">{primarySource.label}</span>
          {article.source_count > 1 && (
            <>
              <span>&middot;</span>
              <span>{article.source_count} fontes</span>
            </>
          )}
          <span>&middot;</span>
          <ReadingTime
            minutes={article.reading_time_min}
            content={article.content_ptbr ?? article.summary_ptbr}
          />
          <span>&middot;</span>
          <span>{formatMediumDate(getEditionDisplayDate(edition))}</span>
        </div>

        <div class="border-t border-foreground/20 mb-8"></div>

        <div class="text-base sm:text-lg leading-relaxed text-foreground/85 mb-8 space-y-4">
          {(article.content_ptbr ?? article.summary_ptbr).split('\n\n').map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>

        <section class="mt-12 mb-2">
          <div class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-[0.5rem] uppercase tracking-[0.18em]">
            <span class="font-bold text-link">
              Fonte principal
            </span>
            <span class="text-link">·</span>
            <a
              href={primarySource.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-foreground/35 transition-colors hover:text-link"
            >
              {primarySource.label} / {getSourceHost(primarySource.url)} &nearr;
            </a>
          </div>
        </section>

        <section class="border-t border-foreground/20 pt-8 mt-4">
          <SectionHeader title="Compartilhar" />
          <ShareButtons title={article.title_ptbr ?? article.title} url={articleUrl} />
        </section>

        {secondarySources.length > 0 && (
          <section class="border-t border-foreground/20 pt-8 mt-4">
            <SectionHeader title="Outras fontes consultadas" />

            <div class="divide-y divide-foreground/10 border-t border-foreground/10">
              {secondarySources.map((source) => (
                <a
                  href={source.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group grid gap-2 py-4 transition-colors hover:text-link sm:grid-cols-[10rem_1fr_auto]"
                >
                  <p class="font-mono text-[0.55rem] uppercase tracking-[0.18em] text-link">
                    {source.label}
                  </p>
                  <div>
                    {source.title && (
                      <h3 class="font-serif text-base font-bold leading-snug text-foreground transition-colors group-hover:text-link">
                        {source.title}
                      </h3>
                    )}
                    {source.snippet && (
                      <p class="mt-1 text-sm leading-relaxed text-foreground/60 line-clamp-2">
                        {source.snippet}
                      </p>
                    )}
                  </div>
                  <span class="font-mono text-[0.55rem] uppercase tracking-[0.18em] text-muted-foreground sm:text-right">
                    Externo &nearr;
                  </span>
                </a>
              ))}
            </div>
          </section>
        )}
      </article>

      {related.length > 0 && (
        <section class="border-t border-foreground/20 pt-10 mt-10">
          <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="mb-2 font-mono text-[0.55rem] font-bold uppercase tracking-[0.24em] text-muted-foreground">
                Continue no DevPulse
              </p>
              <h2 class="font-serif text-2xl font-bold leading-tight">
                Mais em {article.category}
              </h2>
            </div>
            <a
              href={`/categoria/${categorySlug}`}
              class="font-mono text-[0.55rem] uppercase tracking-[0.18em] text-link transition-opacity hover:opacity-70"
            >
              Ver categoria &rarr;
            </a>
          </div>

          <div class="divide-y divide-foreground/10 border-t border-foreground/10">
            {related.map((rel, index) => (
              <a
                href={`/edicao/${edition.slug}/${rel.slug}`}
                class="group grid gap-3 py-5 transition-colors hover:text-link sm:grid-cols-[2.5rem_1fr_auto] sm:items-start"
              >
                <span class="font-mono text-[0.55rem] uppercase tracking-[0.18em] text-muted-foreground">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <div>
                  <h3 class="font-serif text-lg font-bold leading-snug text-foreground transition-colors group-hover:text-link">
                    {rel.title_ptbr ?? rel.title}
                  </h3>
                  <p class="mt-1 text-sm text-foreground/60 line-clamp-2 leading-relaxed">
                    {rel.summary_ptbr}
                  </p>
                  <p class="mt-2 font-mono text-[0.5rem] uppercase tracking-[0.12em] text-link">
                    {getPrimarySource(rel).label}
                    {rel.source_count > 1 ? ` / ${rel.source_count} fontes` : ''}
                    {rel.reading_time_min ? ` / ${rel.reading_time_min} min` : ''}
                  </p>
                </div>
                <span class="font-mono text-[0.55rem] uppercase tracking-[0.18em] text-muted-foreground transition-colors group-hover:text-link sm:text-right">
                  Ler aqui &rarr;
                </span>
              </a>
            ))}
          </div>
        </section>
      )}

      {/* -- CTA SUBSCRIBE -- */}
      <div class="border-t border-foreground/20 pt-6 mt-8 flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3">
        <p class="text-sm text-muted-foreground">
          Receba toda segunda-feira
        </p>
        <button
          data-subscribe-open
          class="text-sm text-link border-b border-link/50 pb-px hover:opacity-70 transition-opacity cursor-pointer"
        >
          Assinar {SITE_NAME} &rarr;
        </button>
      </div>

      <PageFooterNav
        leftLabel="← Mais artigos"
        leftHref="/articles"
        rightLabel="Todas as edições →"
        rightHref="/archive"
      />

    </div>
  </div>
</Layout>
