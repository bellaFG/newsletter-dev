---
import Layout from '@/layouts/Layout.astro'
import PageFooterNav from '@/components/PageFooterNav.astro'
import SectionHeader from '@/components/SectionHeader.astro'
import { supabase } from '@/lib/supabase'
import type { Article, Edition } from '@/lib/types'
import { CATEGORY_SLUGS } from '@/lib/articles'
import { formatMediumDate, formatEditionNumber } from '@/lib/date'
import { SITE_NAME } from '@/lib/config'

const { slug, articleSlug } = Astro.params

const { data: editionData } = await supabase
  .from('editions')
  .select('*')
  .eq('slug', slug!)
  .single()

const edition = editionData as Edition | null
if (!edition) return new Response(null, { status: 404 })

const { data: articleData } = await supabase
  .from('articles')
  .select('*')
  .eq('edition_id', edition.id)
  .eq('slug', articleSlug!)
  .single()

const article = articleData as Article | null
if (!article) return new Response(null, { status: 404 })

const { data: relatedData } = await supabase
  .from('articles')
  .select('*')
  .eq('edition_id', edition.id)
  .eq('category', article.category)
  .neq('id', article.id)
  .order('position', { ascending: true })
  .limit(3)

const related = (relatedData ?? []) as Article[]

const categorySlug = CATEGORY_SLUGS[article.category]
---

<Layout title={`${article.title_ptbr ?? article.title} — ${SITE_NAME}`} description={article.summary_ptbr.slice(0, 160)}>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-3xl px-6 py-10">

      {/* -- BREADCRUMB -- */}
      <nav class="mb-8 font-mono text-[0.55rem] tracking-widest uppercase text-muted-foreground">
        <a href="/" class="text-link hover:opacity-70 transition-colors">Início</a>
        <span class="mx-1">/</span>
        <a href={`/${edition.slug}`} class="text-link hover:opacity-70 transition-colors">
          Edição #{formatEditionNumber(edition.edition_number)}
        </a>
        <span class="mx-1">/</span>
        <span class="text-foreground/60">Artigo</span>
      </nav>

      <article>
        <a
          href={`/categoria/${categorySlug}`}
          class="inline-block font-mono text-[0.5rem] tracking-widest uppercase text-link border border-link/30 px-2 py-0.5 mb-4 hover:bg-link hover:text-white transition-colors"
        >
          {article.category}
        </a>

        <h1 class="font-serif text-3xl sm:text-4xl font-black leading-[1.1] tracking-tight mb-2">
          {article.title_ptbr ?? article.title}
        </h1>
        {article.title_ptbr && article.original_language !== 'pt' && (
          <p class="font-mono text-[0.6rem] text-muted-foreground italic mb-4">
            {article.title}
          </p>
        )}

        <div class="flex flex-wrap items-center gap-2 font-mono text-[0.6rem] text-link mb-8">
          <span class="tracking-widest">{article.source}</span>
          {article.reading_time_min && (
            <>
              <span>&middot;</span>
              <span>{article.reading_time_min} min de leitura</span>
            </>
          )}
          <span>&middot;</span>
          <span>{formatMediumDate(edition.created_at)}</span>
        </div>

        <div class="border-t border-foreground/20 mb-8"></div>

        <div class="text-base sm:text-lg leading-relaxed text-foreground/85 mb-8 space-y-4">
          {(article.content_ptbr ?? article.summary_ptbr).split('\n\n').map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>

        {/* -- CTAs -- */}
        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a
            href={article.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center border-2 border-link/30 text-link font-mono text-[0.6rem] tracking-widest uppercase px-6 py-3 hover:border-link transition-colors font-bold"
          >
            Fonte original &rarr;
          </a>
          <a
            href={`/${edition.slug}`}
            class="inline-flex items-center justify-center font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground px-6 py-3 hover:text-link transition-colors"
          >
            Ver edição #{formatEditionNumber(edition.edition_number)}
          </a>
        </div>
      </article>

      {related.length > 0 && (
        <section class="border-t border-foreground/20 pt-8 mt-4">
          <SectionHeader title={`Mais em ${article.category}`} />

          <div class="space-y-6">
            {related.map((rel) => (
              <a href={`/edicao/${edition.slug}/${rel.slug}`} class="block group">
                <h3 class="font-serif text-lg font-bold leading-snug group-hover:text-link transition-colors mb-1">
                  {rel.title_ptbr ?? rel.title}
                </h3>
                <p class="text-sm text-foreground/60 line-clamp-2 leading-relaxed mb-1">
                  {rel.summary_ptbr}
                </p>
                <p class="font-mono text-[0.5rem] text-link">
                  {rel.source}{rel.reading_time_min ? ` · ${rel.reading_time_min} min` : ''}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}

      {/* -- CTA SUBSCRIBE -- */}
      <div class="border-t border-foreground/20 pt-6 mt-8 flex items-center justify-center gap-3">
        <p class="text-sm text-muted-foreground">
          Receba toda segunda-feira
        </p>
        <button
          data-subscribe-open
          class="text-sm text-link border-b border-link/50 pb-px hover:opacity-70 transition-opacity cursor-pointer"
        >
          Assinar {SITE_NAME} &rarr;
        </button>
      </div>

      <PageFooterNav
        leftLabel={`← Edição #${formatEditionNumber(edition.edition_number)}`}
        leftHref={`/${edition.slug}`}
      />

    </div>
  </div>
</Layout>
