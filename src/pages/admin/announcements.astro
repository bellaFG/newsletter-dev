---
import '@/styles/globals.css'
import { hasAdminSession } from '@/lib/admin-auth'
import { SITE_NAME } from '@/lib/config'
import { createServerClient } from '@/lib/supabase'
import { listSiteAnnouncementsForAdmin } from '@/lib/site-announcements'
import type { SiteAnnouncementRow } from '@/lib/types'

export const prerender = false

const status = Astro.url.searchParams.get('status')
const error = Astro.url.searchParams.get('error')
const editId = Astro.url.searchParams.get('edit')
const isAuthenticated = hasAdminSession(Astro.cookies)

let announcements: SiteAnnouncementRow[] = []
let activeAnnouncement: SiteAnnouncementRow | null = null
let editingAnnouncement: SiteAnnouncementRow | null = null

if (isAuthenticated) {
  const supabase = createServerClient()
  announcements = await listSiteAnnouncementsForAdmin(supabase)
  activeAnnouncement = announcements.find((announcement) => announcement.is_active) ?? null
  editingAnnouncement =
    announcements.find((announcement) => announcement.id === editId) ??
    activeAnnouncement
}

function getFeedbackMessage(statusValue: string | null, errorValue: string | null): string | null {
  if (errorValue === 'auth') return 'Sua sessão expirou. Entre novamente.'
  if (errorValue === 'login') return 'Secret inválido.'
  if (errorValue === 'missing_fields') return 'Preencha título e mensagem.'
  if (errorValue === 'too_long') return 'O título ou a mensagem ficaram grandes demais.'
  if (errorValue === 'save_failed') return 'Não foi possível salvar o recado.'
  if (errorValue === 'invalid_action') return 'A ação solicitada não é válida.'
  if (errorValue === 'missing_id') return 'Não foi possível localizar o recado.'

  if (statusValue === 'login') return 'Sessão iniciada.'
  if (statusValue === 'logout') return 'Sessão encerrada.'
  if (statusValue === 'saved') return 'Recado publicado com sucesso.'
  if (statusValue === 'activated') return 'Recado reativado.'
  if (statusValue === 'deactivated') return 'Recado removido do site.'
  if (statusValue === 'deleted') return 'Recado excluído.'

  return null
}

function formatDateTime(value: string): string {
  return new Date(value).toLocaleString('pt-BR', {
    dateStyle: 'short',
    timeStyle: 'short',
  })
}

const feedbackMessage = getFeedbackMessage(status, error)
const feedbackTone = error ? 'text-destructive border-destructive/30 bg-destructive/5' : 'text-emerald-700 border-emerald-500/30 bg-emerald-500/5'
const formTitle = editingAnnouncement ? 'Editar recado' : 'Novo recado'
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin de recados — {SITE_NAME}</title>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <main class="mx-auto max-w-5xl px-6 py-8 sm:px-10">
      <header class="mb-8 flex flex-wrap items-start justify-between gap-4 border-b border-foreground/15 pb-5">
        <div>
          <p class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-link">Admin</p>
          <h1 class="mt-2 font-serif text-3xl font-black tracking-tight">Mural de avisos</h1>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-foreground/70">
            Publique um recado manual para os assinantes. Quando não houver recado ativo, o site não exibe nada.
          </p>
        </div>

        {isAuthenticated && (
          <form method="post" action="/api/admin/logout">
            <button
              type="submit"
              class="border border-foreground/20 px-4 py-2 font-mono text-[0.6rem] font-bold uppercase tracking-[0.22em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
            >
              Sair
            </button>
          </form>
        )}
      </header>

      {feedbackMessage && (
        <div class:list={[
          'mb-6 border px-4 py-3 text-sm',
          feedbackTone,
        ]}>
          {feedbackMessage}
        </div>
      )}

      {!isAuthenticated ? (
        <section class="mx-auto max-w-md border-2 border-foreground/15 p-6 sm:p-8">
          <h2 class="font-serif text-2xl font-bold tracking-tight">Entrar no painel</h2>
          <p class="mt-2 text-sm leading-relaxed text-foreground/70">
            Use `ADMIN_API_SECRET` se configurado. Se não houver secret dedicado, o painel aceita o mesmo token de `NEWSLETTER_API_SECRET`.
          </p>

          <form method="post" action="/api/admin/login" class="mt-6 space-y-4">
            <input type="hidden" name="redirect_to" value="/admin/announcements" />

            <label class="block">
              <span class="mb-2 block font-mono text-[0.6rem] uppercase tracking-[0.2em] text-muted-foreground">
                Secret
              </span>
              <input
                type="password"
                name="secret"
                required
                class="w-full border border-foreground/20 bg-background px-4 py-3 text-sm focus:border-foreground focus:outline-none"
              />
            </label>

            <button
              type="submit"
              class="w-full border-2 border-link px-5 py-3 font-mono text-[0.65rem] font-bold uppercase tracking-[0.24em] text-link transition-colors hover:bg-link hover:text-white"
            >
              Entrar
            </button>
          </form>
        </section>
      ) : (
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
          <section class="space-y-8">
            <article class="border-2 border-foreground/15 p-6 sm:p-7">
              <div class="mb-5">
                <p class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-link">{formTitle}</p>
                <h2 class="mt-2 font-serif text-2xl font-bold tracking-tight">
                  {editingAnnouncement ? 'Atualize e publique o aviso' : 'Publique um novo aviso'}
                </h2>
              </div>

              <form method="post" action="/api/admin/announcements" class="space-y-5">
                <input type="hidden" name="action" value="save" />
                {editingAnnouncement && (
                  <input type="hidden" name="id" value={editingAnnouncement.id} />
                )}

                <label class="block">
                  <span class="mb-2 block font-mono text-[0.6rem] uppercase tracking-[0.2em] text-muted-foreground">
                    Título
                  </span>
                  <input
                    type="text"
                    name="title"
                    required
                    maxlength="180"
                    value={editingAnnouncement?.title ?? ''}
                    class="w-full border border-foreground/20 bg-background px-4 py-3 text-sm focus:border-foreground focus:outline-none"
                  />
                </label>

                <label class="block">
                  <span class="mb-2 block font-mono text-[0.6rem] uppercase tracking-[0.2em] text-muted-foreground">
                    Mensagem
                  </span>
                  <textarea
                    name="message"
                    required
                    rows={6}
                    maxlength="4000"
                    class="w-full border border-foreground/20 bg-background px-4 py-3 text-sm leading-relaxed focus:border-foreground focus:outline-none"
                  >{editingAnnouncement?.message ?? ''}</textarea>
                </label>

                <label class="flex items-center gap-3">
                  <input
                    type="checkbox"
                    name="dismissible"
                    checked={editingAnnouncement ? editingAnnouncement.dismissible : true}
                    class="h-4 w-4 border border-foreground/20"
                  />
                  <span class="text-sm text-foreground/75">Permitir que o assinante feche o aviso</span>
                </label>

                <div class="flex flex-wrap gap-3">
                  <button
                    type="submit"
                    class="border-2 border-link px-5 py-3 font-mono text-[0.65rem] font-bold uppercase tracking-[0.24em] text-link transition-colors hover:bg-link hover:text-white"
                  >
                    Publicar aviso
                  </button>

                  {editingAnnouncement && (
                    <a
                      href="/admin/announcements"
                      class="border border-foreground/20 px-5 py-3 font-mono text-[0.65rem] font-bold uppercase tracking-[0.24em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
                    >
                      Cancelar edição
                    </a>
                  )}
                </div>
              </form>
            </article>

            <article class="border-2 border-foreground/15 p-6 sm:p-7">
              <div class="mb-5">
                <p class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-link">Histórico</p>
                <h2 class="mt-2 font-serif text-2xl font-bold tracking-tight">Recados salvos</h2>
              </div>

              {announcements.length === 0 ? (
                <p class="text-sm text-foreground/70">Nenhum recado salvo ainda.</p>
              ) : (
                <div class="space-y-4">
                  {announcements.map((announcement) => (
                    <article class="border border-foreground/15 p-4">
                      <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                          <h3 class="font-serif text-xl font-bold tracking-tight">
                            {announcement.title}
                          </h3>
                          <p class="mt-1 font-mono text-[0.55rem] uppercase tracking-[0.22em] text-muted-foreground">
                            {announcement.is_active ? 'Ativo no site' : 'Inativo'} · Atualizado em {formatDateTime(announcement.updated_at)}
                          </p>
                        </div>
                        <div class="flex flex-wrap gap-2">
                          <a
                            href={`/admin/announcements?edit=${announcement.id}`}
                            class="border border-foreground/20 px-3 py-2 font-mono text-[0.55rem] font-bold uppercase tracking-[0.2em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
                          >
                            Editar
                          </a>

                          {!announcement.is_active && (
                            <form method="post" action="/api/admin/announcements">
                              <input type="hidden" name="action" value="activate" />
                              <input type="hidden" name="id" value={announcement.id} />
                              <button
                                type="submit"
                                class="border border-link px-3 py-2 font-mono text-[0.55rem] font-bold uppercase tracking-[0.2em] text-link transition-colors hover:bg-link hover:text-white"
                              >
                                Publicar
                              </button>
                            </form>
                          )}

                          {announcement.is_active && (
                            <form method="post" action="/api/admin/announcements">
                              <input type="hidden" name="action" value="deactivate" />
                              <input type="hidden" name="id" value={announcement.id} />
                              <button
                                type="submit"
                                class="border border-amber-600 px-3 py-2 font-mono text-[0.55rem] font-bold uppercase tracking-[0.2em] text-amber-700 transition-colors hover:bg-amber-600 hover:text-white"
                              >
                                Desativar
                              </button>
                            </form>
                          )}

                          <form method="post" action="/api/admin/announcements">
                            <input type="hidden" name="action" value="delete" />
                            <input type="hidden" name="id" value={announcement.id} />
                            <button
                              type="submit"
                              class="border border-destructive/30 px-3 py-2 font-mono text-[0.55rem] font-bold uppercase tracking-[0.2em] text-destructive transition-colors hover:bg-destructive hover:text-white"
                            >
                              Excluir
                            </button>
                          </form>
                        </div>
                      </div>

                      <p class="mt-3 text-sm leading-relaxed text-foreground/75">
                        {announcement.message}
                      </p>
                    </article>
                  ))}
                </div>
              )}
            </article>
          </section>

          <aside class="space-y-6">
            <article class="border-2 border-foreground/15 p-6">
              <p class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-link">Status atual</p>
              <h2 class="mt-2 font-serif text-2xl font-bold tracking-tight">Aviso no ar</h2>

              {activeAnnouncement ? (
                <div class="mt-5 space-y-3">
                  <div>
                    <p class="font-serif text-xl font-bold tracking-tight">{activeAnnouncement.title}</p>
                    <p class="mt-2 text-sm leading-relaxed text-foreground/75">{activeAnnouncement.message}</p>
                  </div>

                  <dl class="space-y-2 text-sm text-foreground/70">
                    <div>
                      <dt class="font-mono text-[0.55rem] uppercase tracking-[0.2em] text-muted-foreground">Dismissível</dt>
                      <dd>{activeAnnouncement.dismissible ? 'Sim' : 'Não'}</dd>
                    </div>
                    <div>
                      <dt class="font-mono text-[0.55rem] uppercase tracking-[0.2em] text-muted-foreground">Atualizado em</dt>
                      <dd>{formatDateTime(activeAnnouncement.updated_at)}</dd>
                    </div>
                  </dl>
                </div>
              ) : (
                <p class="mt-4 text-sm leading-relaxed text-foreground/70">
                  Nenhum aviso ativo. O topo do site permanece limpo até você publicar um novo recado.
                </p>
              )}
            </article>

            <article class="border-2 border-foreground/15 p-6">
              <p class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-link">Comportamento</p>
              <ul class="mt-4 space-y-3 text-sm leading-relaxed text-foreground/70">
                <li>O aviso aparece no topo do site apenas quando existe um recado ativo.</li>
                <li>O usuário pode fechar o aviso quando `dismissible` estiver habilitado.</li>
                <li>Ao editar e republicar, a chave de dismiss muda e o aviso volta a aparecer.</li>
              </ul>
            </article>
          </aside>
        </div>
      )}
    </main>
  </body>
</html>
