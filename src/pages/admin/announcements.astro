---
import '@/styles/globals.css'
import { hasAdminSession } from '@/lib/admin-auth'
import { SITE_NAME } from '@/lib/config'
import { createServerClient } from '@/lib/supabase'
import { listSiteAnnouncementsForAdmin } from '@/lib/site-announcements'
import type { SiteAnnouncementRow } from '@/lib/types'

export const prerender = false

const status = Astro.url.searchParams.get('status')
const error = Astro.url.searchParams.get('error')
const editId = Astro.url.searchParams.get('edit')
const isAuthenticated = hasAdminSession(Astro.cookies)

let announcements: SiteAnnouncementRow[] = []
let activeAnnouncement: SiteAnnouncementRow | null = null
let editingAnnouncement: SiteAnnouncementRow | null = null

if (isAuthenticated) {
  const supabase = createServerClient()
  announcements = await listSiteAnnouncementsForAdmin(supabase)
  activeAnnouncement = announcements.find((announcement) => announcement.is_active) ?? null
  editingAnnouncement = editId
    ? announcements.find((announcement) => announcement.id === editId) ?? null
    : null
}

function getFeedbackMessage(statusValue: string | null, errorValue: string | null): string | null {
  if (errorValue === 'auth') return 'Sua sessão expirou. Entre novamente.'
  if (errorValue === 'login') return 'Secret inválido.'
  if (errorValue === 'rate_limit') return 'Muitas tentativas. Aguarde alguns minutos antes de tentar de novo.'
  if (errorValue === 'origin') return 'A solicitação foi bloqueada por segurança.'
  if (errorValue === 'missing_fields') return 'Preencha título e mensagem.'
  if (errorValue === 'too_long') return 'O título ou a mensagem ficaram grandes demais.'
  if (errorValue === 'save_failed') return 'Não foi possível salvar o recado.'
  if (errorValue === 'invalid_action') return 'A ação solicitada não é válida.'
  if (errorValue === 'missing_id') return 'Não foi possível localizar o recado.'

  if (statusValue === 'login') return 'Sessão iniciada.'
  if (statusValue === 'logout') return 'Sessão encerrada.'
  if (statusValue === 'saved') return 'Recado publicado com sucesso.'
  if (statusValue === 'activated') return 'Recado reativado.'
  if (statusValue === 'deactivated') return 'Recado removido do site.'
  if (statusValue === 'deleted') return 'Recado excluído.'

  return null
}

function formatDateTime(value: string): string {
  return new Date(value).toLocaleString('pt-BR', {
    dateStyle: 'short',
    timeStyle: 'short',
  })
}

function summarizeMessage(value: string, maxLength = 140): string {
  const compact = value.replace(/\s+/g, ' ').trim()
  if (compact.length <= maxLength) return compact
  return `${compact.slice(0, maxLength).trimEnd()}…`
}

function encodeForData(value: string): string {
  return encodeURIComponent(value)
}

const feedbackMessage = getFeedbackMessage(status, error)
const feedbackTone = error
  ? 'text-destructive border-destructive/30 bg-destructive/5'
  : 'text-emerald-700 border-emerald-500/30 bg-emerald-500/5'
const submitLabel = editingAnnouncement ? 'Atualizar e exibir' : 'Exibir recado'
const titleValue = editingAnnouncement?.title ?? ''
const messageValue = editingAnnouncement?.message ?? ''
const dismissibleValue = editingAnnouncement ? editingAnnouncement.dismissible : true
const previewTitle = titleValue || 'Seu próximo recado aparece aqui'
const previewMessage =
  messageValue ||
  'Escreva o texto do aviso para ver aqui como ele aparece no topo do site.'
const latestAnnouncement = announcements[0] ?? null
const reusableAnnouncements = announcements.slice(0, 10)
const totalAnnouncements = announcements.length
const latestUpdatedAt = latestAnnouncement ? formatDateTime(latestAnnouncement.updated_at) : 'Sem histórico'
const activeStatusLabel = activeAnnouncement ? 'Recado no ar' : 'Sem recado ativo'
const activeStatusTitle = activeAnnouncement?.title ?? 'Nenhum recado exibido'
const activeStatusMessage = activeAnnouncement
  ? summarizeMessage(activeAnnouncement.message, 120)
  : 'Crie um recado para ocupar o topo do site.'
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin de recados — {SITE_NAME}</title>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <main class="mx-auto max-w-6xl px-6 py-8 sm:px-10">
      <header class="mb-8 border-b border-foreground/15 pb-6">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <h1 class="font-serif text-3xl font-black tracking-tight sm:text-4xl">Mural de recados</h1>
          </div>

          {isAuthenticated && (
            <form method="post" action="/api/admin/logout">
              <button
                type="submit"
                class="border border-foreground/20 px-4 py-2 font-mono text-[0.6rem] font-bold uppercase tracking-[0.22em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
              >
                Sair
              </button>
            </form>
          )}
        </div>
      </header>

      {feedbackMessage && (
        <div class:list={['mb-6 border px-4 py-3 text-sm shadow-sm', feedbackTone]}>
          {feedbackMessage}
        </div>
      )}

      {!isAuthenticated ? (
        <section class="mx-auto max-w-md border-2 border-foreground/15 bg-[linear-gradient(180deg,rgba(37,99,235,0.06),transparent_65%)] p-6 sm:p-8">
          <h2 class="font-serif text-2xl font-bold tracking-tight">Entrar no painel</h2>

          <form method="post" action="/api/admin/login" class="mt-6 space-y-4">
            <input type="hidden" name="redirect_to" value="/admin/announcements" />

            <label class="block">
              <span class="mb-2 block font-mono text-[0.6rem] uppercase tracking-[0.2em] text-muted-foreground">
                Secret
              </span>
              <input
                type="password"
                name="secret"
                required
                class="w-full border border-foreground/20 bg-background px-4 py-3 text-sm focus:border-foreground focus:outline-none"
              />
            </label>

            <button
              type="submit"
              class="w-full border-2 border-link px-5 py-3 font-mono text-[0.65rem] font-bold uppercase tracking-[0.24em] text-link transition-colors hover:bg-link hover:text-white"
            >
              Entrar
            </button>
          </form>
        </section>
      ) : (
        <div class="xl:grid xl:grid-cols-[minmax(0,1fr)_280px] xl:gap-8">
          <section class="mx-auto max-w-3xl xl:mx-0 xl:max-w-none">
            <div class="mb-8 grid gap-3 sm:grid-cols-3 xl:hidden">
              <article class="border border-foreground/15 bg-background/80 p-4">
                <p class="font-mono text-[0.55rem] uppercase tracking-[0.2em] text-muted-foreground">
                  Status
                </p>
                <p class="mt-3 font-serif text-xl font-black tracking-tight">{activeStatusLabel}</p>
              </article>

              <article class="border border-foreground/15 bg-background/80 p-4">
                <p class="font-mono text-[0.55rem] uppercase tracking-[0.2em] text-muted-foreground">
                  Total
                </p>
                <p class="mt-3 font-serif text-xl font-black tracking-tight">{totalAnnouncements}</p>
              </article>

              <article class="border border-foreground/15 bg-background/80 p-4 sm:col-span-3">
                <p class="font-mono text-[0.55rem] uppercase tracking-[0.2em] text-muted-foreground">
                  Ativo agora
                </p>
                <p class="mt-3 font-serif text-xl font-black tracking-tight">{activeStatusTitle}</p>
              </article>
            </div>

            <article class="mx-auto max-w-3xl border-2 border-link/25 bg-link/5 p-6 shadow-[0_16px_50px_rgba(37,99,235,0.08)] sm:p-7">
              <div class="mb-4 flex items-start justify-between gap-4">
                <p class="font-mono text-[0.55rem] font-bold uppercase tracking-[0.22em] text-link">
                  Exibição no site
                </p>

                <button
                  type="button"
                  disabled
                  class:list={[
                    'font-mono text-sm leading-none text-muted-foreground',
                    !dismissibleValue && 'hidden',
                  ]}
                  data-preview-close
                  aria-hidden={dismissibleValue ? 'false' : 'true'}
                >
                  &times;
                </button>
              </div>

              <div class="max-w-2xl">
                <h2
                  class:list={[
                    'font-serif text-2xl font-black tracking-tight text-foreground sm:text-3xl',
                    !titleValue && 'text-foreground/45',
                  ]}
                  data-preview-title
                >
                  {previewTitle}
                </h2>
                <p
                  class:list={[
                    'mt-3 whitespace-pre-line text-sm leading-relaxed text-foreground/75 sm:text-base',
                    !messageValue && 'italic text-foreground/55',
                  ]}
                  data-preview-message
                >
                  {previewMessage}
                </p>
              </div>
            </article>

            <article
              id="announcement-form"
              class="mt-8 border-2 border-foreground/15 bg-[linear-gradient(180deg,rgba(37,99,235,0.06),transparent_50%)] p-6 sm:p-7"
            >
              <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
                <h2 class="font-serif text-2xl font-bold tracking-tight">Escrever recado</h2>

                <a
                  href="/admin/announcements"
                  class="border border-foreground/20 px-4 py-2 font-mono text-[0.6rem] font-bold uppercase tracking-[0.22em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
                >
                  Novo
                </a>
              </div>

              {editingAnnouncement && (
                <div
                  class="mb-5 flex flex-wrap items-center justify-between gap-3 border border-amber-500/25 bg-amber-500/10 px-4 py-3"
                  data-editing-state
                >
                  <div class="min-w-0">
                    <p class="font-mono text-[0.55rem] uppercase tracking-[0.2em] text-amber-700">
                      Editando
                    </p>
                    <p class="truncate font-serif text-lg font-bold tracking-tight">
                      {editingAnnouncement.title}
                    </p>
                  </div>

                  <a
                    href="/admin/announcements"
                    class="border border-amber-600/30 px-3 py-2 font-mono text-[0.55rem] font-bold uppercase tracking-[0.2em] text-amber-700 transition-colors hover:border-amber-700 hover:text-amber-900"
                  >
                    Sair da edição
                  </a>
                </div>
              )}

              <form
                method="post"
                action="/api/admin/announcements"
                class="space-y-5"
                data-announcement-form
              >
                <input type="hidden" name="action" value="save" />
                {editingAnnouncement && (
                  <input
                    type="hidden"
                    name="id"
                    value={editingAnnouncement.id}
                    data-edit-id-input
                  />
                )}

                <label class="block">
                  <div class="mb-2 flex items-center justify-between gap-3">
                    <span class="font-mono text-[0.6rem] uppercase tracking-[0.2em] text-muted-foreground">
                      Título
                    </span>
                    <span
                      class="font-mono text-[0.55rem] uppercase tracking-[0.18em] text-muted-foreground"
                      data-title-count
                    >
                      {titleValue.length}/180
                    </span>
                  </div>
                  <input
                    type="text"
                    name="title"
                    required
                    maxlength="180"
                    value={titleValue}
                    placeholder="Ex.: Nova edição sai hoje às 9h"
                    class="w-full border border-foreground/20 bg-background px-4 py-3 text-sm focus:border-foreground focus:outline-none"
                  />
                </label>

                <label class="block">
                  <div class="mb-2 flex items-center justify-between gap-3">
                    <span class="font-mono text-[0.6rem] uppercase tracking-[0.2em] text-muted-foreground">
                      Mensagem
                    </span>
                    <span
                      class="font-mono text-[0.55rem] uppercase tracking-[0.18em] text-muted-foreground"
                      data-message-count
                    >
                      {messageValue.length}/4000
                    </span>
                  </div>
                  <textarea
                    name="message"
                    required
                    rows={7}
                    maxlength="4000"
                    placeholder="Escreva o aviso como ele deve aparecer no site."
                    class="w-full border border-foreground/20 bg-background px-4 py-3 text-sm leading-relaxed focus:border-foreground focus:outline-none"
                  >{messageValue}</textarea>
                </label>

                <div class="rounded-sm border border-foreground/15 bg-background/80 px-4 py-3">
                  <label class="flex items-center gap-3">
                    <input
                      type="checkbox"
                      name="dismissible"
                      checked={dismissibleValue}
                      class="h-4 w-4 border border-foreground/20"
                    />
                    <span class="text-sm text-foreground/75">Mostrar botão de fechar</span>
                  </label>
                </div>

                <div class="flex flex-wrap gap-3">
                  <button
                    type="submit"
                    class="border-2 border-link px-5 py-3 font-mono text-[0.65rem] font-bold uppercase tracking-[0.24em] text-link transition-colors hover:bg-link hover:text-white"
                    data-submit-button
                  >
                    {submitLabel}
                  </button>
                </div>
              </form>
            </article>

            <article class="mt-8 border-2 border-foreground/15 p-6 sm:p-7">
              <div class="mb-5 flex flex-wrap items-center justify-between gap-4">
                <h2 class="font-serif text-2xl font-bold tracking-tight">Histórico</h2>
                <span class="border border-foreground/15 px-3 py-1 font-mono text-[0.55rem] uppercase tracking-[0.2em] text-muted-foreground">
                  {totalAnnouncements} item{totalAnnouncements === 1 ? '' : 's'}
                </span>
              </div>

              {reusableAnnouncements.length === 0 ? (
                <div class="border border-dashed border-foreground/20 px-5 py-10 text-center">
                  <p class="font-mono text-[0.55rem] uppercase tracking-[0.22em] text-muted-foreground">
                    Sem recados
                  </p>
                </div>
              ) : (
                <div class="space-y-4">
                  {reusableAnnouncements.map((announcement) => (
                    <article
                      class:list={[
                        'border p-4 transition-colors',
                        announcement.is_active ? 'border-link/30 bg-link/5' : 'border-foreground/15',
                        editingAnnouncement?.id === announcement.id && 'ring-1 ring-link/35',
                      ]}
                    >
                      <div class="flex flex-wrap items-start justify-between gap-4">
                        <div class="min-w-0 flex-1">
                          <div class="flex flex-wrap items-center gap-2">
                            <h3 class="font-serif text-xl font-bold tracking-tight">
                              {announcement.title}
                            </h3>
                            {announcement.is_active && (
                              <span class="border border-link/30 bg-link/10 px-2 py-0.5 font-mono text-[0.5rem] uppercase tracking-[0.18em] text-link">
                                No ar
                              </span>
                            )}
                          </div>

                          <p class="mt-2 font-mono text-[0.55rem] uppercase tracking-[0.22em] text-muted-foreground">
                            {formatDateTime(announcement.updated_at)}
                          </p>
                        </div>
                      </div>

                      <p class="mt-4 whitespace-pre-line text-sm leading-relaxed text-foreground/75">
                        {announcement.message}
                      </p>

                      <div class="mt-4 flex flex-wrap gap-2">
                        <button
                          type="button"
                          class="border border-link px-3 py-2 font-mono text-[0.55rem] font-bold uppercase tracking-[0.2em] text-link transition-colors hover:bg-link hover:text-white"
                          data-reuse-announcement
                          data-reuse-title={encodeForData(announcement.title)}
                          data-reuse-message={encodeForData(announcement.message)}
                          data-reuse-dismissible={announcement.dismissible ? 'true' : 'false'}
                        >
                          Reusar
                        </button>

                        <a
                          href={`/admin/announcements?edit=${announcement.id}`}
                          class="border border-foreground/20 px-3 py-2 font-mono text-[0.55rem] font-bold uppercase tracking-[0.2em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
                        >
                          Editar
                        </a>

                        {!announcement.is_active && (
                          <form method="post" action="/api/admin/announcements">
                            <input type="hidden" name="action" value="activate" />
                            <input type="hidden" name="id" value={announcement.id} />
                            <button
                              type="submit"
                              class="border border-link px-3 py-2 font-mono text-[0.55rem] font-bold uppercase tracking-[0.2em] text-link transition-colors hover:bg-link hover:text-white"
                            >
                              Exibir
                            </button>
                          </form>
                        )}

                        {announcement.is_active && (
                          <form method="post" action="/api/admin/announcements">
                            <input type="hidden" name="action" value="deactivate" />
                            <input type="hidden" name="id" value={announcement.id} />
                            <button
                              type="submit"
                              class="border border-amber-600 px-3 py-2 font-mono text-[0.55rem] font-bold uppercase tracking-[0.2em] text-amber-700 transition-colors hover:bg-amber-600 hover:text-white"
                            >
                              Tirar do ar
                            </button>
                          </form>
                        )}

                        <form method="post" action="/api/admin/announcements">
                          <input type="hidden" name="action" value="delete" />
                          <input type="hidden" name="id" value={announcement.id} />
                          <button
                            type="submit"
                            class="border border-destructive/30 px-3 py-2 font-mono text-[0.55rem] font-bold uppercase tracking-[0.2em] text-destructive transition-colors hover:bg-destructive hover:text-white"
                          >
                            Excluir
                          </button>
                        </form>
                      </div>
                    </article>
                  ))}
                </div>
              )}
            </article>
          </section>

          <aside class="mt-8 hidden self-start xl:sticky xl:top-8 xl:block">
            <article class="border-2 border-foreground/15 p-6">
              <p class="font-mono text-[0.6rem] uppercase tracking-[0.24em] text-link">
                Status
              </p>

              <div class="mt-5 space-y-4">
                <div class="border border-foreground/15 p-4">
                  <div class="mb-3 flex items-start justify-between gap-3">
                    <span
                      class:list={[
                        'border px-2 py-0.5 font-mono text-[0.5rem] uppercase tracking-[0.18em]',
                        activeAnnouncement
                          ? 'border-link/30 bg-link/10 text-link'
                          : 'border-foreground/15 text-muted-foreground',
                      ]}
                    >
                      {activeAnnouncement ? 'Ativo' : 'Sem ativo'}
                    </span>

                    {activeAnnouncement?.dismissible && (
                      <span class="font-mono text-sm leading-none text-muted-foreground">
                        &times;
                      </span>
                    )}
                  </div>

                  <h3 class="font-serif text-xl font-bold tracking-tight">
                    {activeStatusTitle}
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-foreground/70">
                    {activeStatusMessage}
                  </p>
                </div>

                <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-1">
                  <article class="border border-foreground/15 p-4">
                    <p class="font-mono text-[0.55rem] uppercase tracking-[0.22em] text-muted-foreground">
                      Total
                    </p>
                    <p class="mt-3 font-serif text-3xl font-black tracking-tight">
                      {totalAnnouncements}
                    </p>
                  </article>

                  <article class="border border-foreground/15 p-4">
                    <p class="font-mono text-[0.55rem] uppercase tracking-[0.22em] text-muted-foreground">
                      Última atualização
                    </p>
                    <p class="mt-3 font-serif text-lg font-black tracking-tight">
                      {latestUpdatedAt}
                    </p>
                  </article>
                </div>
              </div>
            </article>
          </aside>
        </div>
      )}
    </main>

    {isAuthenticated && (
      <script>
        (() => {
          const form = document.querySelector<HTMLFormElement>('[data-announcement-form]')
          if (!(form instanceof HTMLFormElement)) return

          const titleInput = form.querySelector<HTMLInputElement>('input[name="title"]')
          const messageInput = form.querySelector<HTMLTextAreaElement>('textarea[name="message"]')
          const dismissibleInput =
            form.querySelector<HTMLInputElement>('input[name="dismissible"]')
          const editIdInput = form.querySelector<HTMLInputElement>('[data-edit-id-input]')
          const editingState = document.querySelector<HTMLElement>('[data-editing-state]')
          const titleCount = document.querySelector<HTMLElement>('[data-title-count]')
          const messageCount = document.querySelector<HTMLElement>('[data-message-count]')
          const previewTitle = document.querySelector<HTMLElement>('[data-preview-title]')
          const previewMessage = document.querySelector<HTMLElement>('[data-preview-message]')
          const previewClose = document.querySelector<HTMLElement>('[data-preview-close]')
          const submitButton = document.querySelector<HTMLElement>('[data-submit-button]')
          const reuseButtons =
            document.querySelectorAll<HTMLButtonElement>('[data-reuse-announcement]')

          if (
            !titleInput ||
            !messageInput ||
            !dismissibleInput ||
            !titleCount ||
            !messageCount ||
            !previewTitle ||
            !previewMessage ||
            !previewClose ||
            !submitButton
          ) {
            return
          }

          const titleField = titleInput
          const messageField = messageInput
          const dismissibleField = dismissibleInput
          const editIdField = editIdInput
          const editingStateBanner = editingState
          const titleCounter = titleCount
          const messageCounter = messageCount
          const previewTitleField = previewTitle
          const previewMessageField = previewMessage
          const previewCloseField = previewClose
          const submitButtonField = submitButton

          const titleMax = Number(titleField.getAttribute('maxlength') || '180')
          const messageMax = Number(messageField.getAttribute('maxlength') || '4000')

          function enterCreateMode() {
            if (editIdField) {
              editIdField.disabled = true
              editIdField.value = ''
            }

            if (editingStateBanner) {
              editingStateBanner.hidden = true
            }

            submitButtonField.textContent = 'Exibir recado'

            if (window.location.search.includes('edit=')) {
              window.history.replaceState({}, '', '/admin/announcements')
            }
          }

          function syncPreview() {
            const title = titleField.value.trim()
            const message = messageField.value.trim()
            const dismissible = dismissibleField.checked

            titleCounter.textContent = `${titleField.value.length}/${titleMax}`
            messageCounter.textContent = `${messageField.value.length}/${messageMax}`

            previewTitleField.textContent = title || 'Seu próximo recado aparece aqui'
            previewMessageField.textContent =
              message ||
              'Escreva o texto do aviso para ver aqui como ele aparece no topo do site.'
            previewCloseField.classList.toggle('hidden', !dismissible)
            previewCloseField.setAttribute('aria-hidden', dismissible ? 'false' : 'true')

            previewTitleField.classList.toggle('text-foreground/45', !title)
            previewMessageField.classList.toggle('italic', !message)
            previewMessageField.classList.toggle('text-foreground/55', !message)
          }

          titleField.addEventListener('input', syncPreview)
          messageField.addEventListener('input', syncPreview)
          dismissibleField.addEventListener('change', syncPreview)

          reuseButtons.forEach((button) => {
            button.addEventListener('click', () => {
              const title = decodeURIComponent(button.dataset.reuseTitle ?? '')
              const message = decodeURIComponent(button.dataset.reuseMessage ?? '')
              const dismissible = button.dataset.reuseDismissible === 'true'

              enterCreateMode()
              titleField.value = title
              messageField.value = message
              dismissibleField.checked = dismissible
              syncPreview()
              titleField.focus()
              titleField.setSelectionRange(titleField.value.length, titleField.value.length)
              form.scrollIntoView({ behavior: 'smooth', block: 'start' })
            })
          })

          syncPreview()
        })()
      </script>
    )}
  </body>
</html>
