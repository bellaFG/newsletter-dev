---
import Layout from '@/layouts/Layout.astro'
import { supabase } from '@/lib/supabase'
import type { Article, Edition } from '@/lib/types'
import { formatFullDate, formatMediumDate, formatShortDate, formatEditionNumber } from '@/lib/date'
import { SITE_NAME, SITE_TAGLINE, MASTHEAD_SUBTITLE } from '@/lib/config'

// \u00daltima edi\u00e7\u00e3o
const { data: latestData } = await supabase
  .from('editions')
  .select('*')
  .order('edition_number', { ascending: false })
  .limit(1)
  .single()

const latest = latestData as Edition | null

// Artigos da \u00faltima edi\u00e7\u00e3o
let articles: Article[] = []
if (latest) {
  const { data } = await supabase
    .from('articles')
    .select('*')
    .eq('edition_id', latest.id)
    .order('position', { ascending: true })
  articles = (data ?? []) as Article[]
}

const hero = articles[0] ?? null
const sidebarArticles = articles.slice(1, 3)
const gridArticles = articles.slice(3, 6)

// Edi\u00e7\u00f5es anteriores para o arquivo
const { data: archiveData } = await supabase
  .from('editions')
  .select('id, slug, edition_number, title, created_at')
  .order('edition_number', { ascending: false })
  .range(1, 5)

const recentEditions = (archiveData ?? []) as Pick<
  Edition,
  'id' | 'slug' | 'edition_number' | 'title' | 'created_at'
>[]

const today = formatFullDate(new Date())
---

<Layout>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-4xl px-6 py-10">

      {/* ── MASTHEAD ── */}
      <header class="border-b-2 border-foreground/40 pb-5 mb-1">
        <div class="flex items-center justify-between mb-3">
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground">
            {today}
          </p>
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground hidden sm:block">
            {SITE_TAGLINE}
          </p>
        </div>
        <div class="text-center py-2">
          <h1 class="font-serif text-[clamp(3rem,10vw,6.5rem)] font-black leading-none tracking-tighter uppercase">
            {SITE_NAME.toUpperCase()}
          </h1>
          <div class="mt-3 flex items-center gap-3 justify-center">
            <div class="h-px w-16 bg-foreground/25"></div>
            <p class="font-mono text-[0.6rem] tracking-[0.25em] uppercase text-muted-foreground">
              {MASTHEAD_SUBTITLE}
            </p>
            <div class="h-px w-16 bg-foreground/25"></div>
          </div>
        </div>
      </header>
      <div class="border-t border-foreground/20 mt-1 mb-8"></div>

      {latest && hero ? (
        <>
          {/* ── EDI\u00c7\u00c3O ATUAL: LABEL ── */}
          <div class="flex items-center gap-3 mb-6">
            <p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground shrink-0">
              Edição nº {latest.edition_number} &mdash;{' '}
              {formatMediumDate(latest.created_at)}
            </p>
            <div class="h-px flex-1 bg-border"></div>
          </div>

          {/* ── HERO + SIDEBAR ── */}
          <div class="grid grid-cols-1 lg:grid-cols-5 gap-0 divide-y lg:divide-y-0 lg:divide-x divide-border mb-0">

            {/* Hero article */}
            <article class="lg:col-span-3 lg:pr-8 pb-8 lg:pb-0">
              <p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground mb-2">
                {hero.category}
              </p>
              <a href={`/${latest.slug}`}>
                <h2 class="font-serif text-3xl sm:text-4xl font-bold leading-tight tracking-tight mb-3 hover:opacity-60 transition-opacity">
                  {hero.title}
                </h2>
              </a>
              <p class="font-mono text-[0.65rem] text-muted-foreground mb-4 flex items-center gap-2">
                <span>{hero.source}</span>
                {hero.reading_time_min && (
                  <>
                    <span>&middot;</span>
                    <span>{hero.reading_time_min} min de leitura</span>
                  </>
                )}
              </p>
              <p class="text-base leading-relaxed text-foreground/80 line-clamp-5">
                {hero.summary_ptbr}
              </p>
              <a
                href={`/${latest.slug}`}
                class="mt-5 inline-block font-mono text-[0.65rem] tracking-widest uppercase border-b border-foreground pb-px hover:opacity-60 transition-opacity"
              >
                Ler edição completa &rarr;
              </a>
            </article>

            {/* Sidebar: 2 artigos secund\u00e1rios */}
            {sidebarArticles.length > 0 && (
              <aside class="lg:col-span-2 lg:pl-8 pt-8 lg:pt-0 space-y-6">
                {sidebarArticles.map((article) => (
                  <a href={`/${latest.slug}`} class="block group">
                    <p class="font-mono text-[0.55rem] tracking-widest uppercase text-muted-foreground mb-1">
                      {article.category}
                    </p>
                    <h3 class="font-serif text-lg font-semibold leading-snug group-hover:opacity-60 transition-opacity mb-2">
                      {article.title}
                    </h3>
                    <p class="text-sm text-muted-foreground line-clamp-3 leading-relaxed">
                      {article.summary_ptbr}
                    </p>
                  </a>
                ))}
              </aside>
            )}
          </div>

          {/* ── GRID 3 COLUNAS ── */}
          {gridArticles.length > 0 && (
            <>
              <div class="border-t border-foreground/20 my-8"></div>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-0 divide-y sm:divide-y-0 sm:divide-x divide-border">
                {gridArticles.map((article) => (
                  <a
                    href={`/${latest.slug}`}
                    class="block group py-6 sm:py-0 sm:px-6 first:sm:pl-0 last:sm:pr-0"
                  >
                    <p class="font-mono text-[0.55rem] tracking-widest uppercase text-muted-foreground mb-1">
                      {article.category}
                    </p>
                    <h3 class="font-serif text-base font-semibold leading-snug group-hover:opacity-60 transition-opacity mb-2">
                      {article.title}
                    </h3>
                    <p class="text-sm text-muted-foreground line-clamp-4 leading-relaxed">
                      {article.summary_ptbr}
                    </p>
                  </a>
                ))}
              </div>
            </>
          )}
        </>
      ) : (
        <div class="py-16 text-center border-y border-border">
          <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-3">
            Em breve
          </p>
          <h2 class="font-serif text-3xl font-bold mb-4">
            A primeira edição chega segunda-feira.
          </h2>
          <p class="text-muted-foreground max-w-sm mx-auto">
            Inscreva-se para receber {SITE_NAME} diretamente no seu email.
          </p>
        </div>
      )}

      {/* ── SUBSCRIBE ── */}
      <div class="py-14 my-10 text-center">
        <div class="max-w-sm mx-auto">
          <p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground mb-3">
            Receba toda segunda-feira
          </p>
          <h2 class="font-serif text-2xl sm:text-3xl font-bold mb-2">
            Assine o {SITE_NAME}
          </h2>
          <p class="text-sm text-muted-foreground mb-8">
            Curadoria semanal gratuita, direto no seu email.
          </p>
          <form id="subscribe-form" class="flex flex-col sm:flex-row gap-3">
            <input
              type="email"
              name="email"
              placeholder="seu@email.com"
              required
              class="flex-1 border border-foreground/20 bg-background px-4 py-3 text-sm font-mono placeholder:text-muted-foreground focus:outline-none focus:border-foreground/50 transition-colors"
            />
            <button
              type="submit"
              class="bg-foreground text-background font-mono text-[0.65rem] tracking-widest uppercase px-6 py-3 hover:opacity-75 transition-opacity cursor-pointer"
            >
              Assinar
            </button>
          </form>
          <p id="subscribe-msg" class="mt-4 text-sm font-mono hidden"></p>
        </div>
      </div>

      {/* ── EDI\u00c7\u00d5ES ANTERIORES ── */}
      {recentEditions.length > 0 && (
        <section class="mb-10">
          <div class="flex items-center gap-3 mb-5">
            <p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground shrink-0">
              Edições anteriores
            </p>
            <div class="h-px flex-1 bg-border"></div>
          </div>
          <ul class="divide-y divide-border">
            {recentEditions.map((edition) => (
              <li>
                <a
                  href={`/${edition.slug}`}
                  class="flex items-baseline justify-between py-4 hover:opacity-60 transition-opacity group"
                >
                  <span class="font-mono text-[0.65rem] text-muted-foreground mr-4 shrink-0">
                    #{formatEditionNumber(edition.edition_number)}
                  </span>
                  <span class="font-serif text-base font-semibold flex-1 group-hover:underline underline-offset-2">
                    {edition.title}
                  </span>
                  <span class="font-mono text-[0.65rem] text-muted-foreground ml-4 shrink-0">
                    {formatShortDate(edition.created_at)}
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <div class="mt-5 text-center">
            <a
              href="/archive"
              class="font-mono text-[0.65rem] tracking-widest uppercase border-b border-muted-foreground pb-px text-muted-foreground hover:text-foreground hover:border-foreground transition-colors"
            >
              Ver todas as edições &rarr;
            </a>
          </div>
        </section>
      )}

    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement
  const msg = document.getElementById('subscribe-msg') as HTMLParagraphElement

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const email = (form.elements.namedItem('email') as HTMLInputElement).value

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      })
      const data = await res.json()

      msg.classList.remove('hidden')
      if (res.ok) {
        msg.textContent = 'Inscrito com sucesso! Até segunda-feira.'
        msg.className = 'mt-4 text-sm font-mono text-foreground'
        form.reset()
      } else {
        msg.textContent = data.error ?? 'Erro ao inscrever. Tente novamente.'
        msg.className = 'mt-4 text-sm font-mono text-destructive'
      }
    } catch {
      msg.classList.remove('hidden')
      msg.textContent = 'Erro de conexão. Tente novamente.'
      msg.className = 'mt-4 text-sm font-mono text-destructive'
    }
  })
</script>
