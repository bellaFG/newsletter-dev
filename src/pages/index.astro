---
import Layout from '@/layouts/Layout.astro'
import { supabase } from '@/lib/supabase'
import type { Article, Edition } from '@/lib/types'
import { formatFullDate, formatMediumDate, formatShortDate, formatEditionNumber } from '@/lib/date'
import { groupByCategory, getOrderedCategories } from '@/lib/articles'
import { SITE_NAME, SITE_TAGLINE, MASTHEAD_SUBTITLE } from '@/lib/config'

// Última edição
const { data: latestData } = await supabase
  .from('editions')
  .select('*')
  .order('edition_number', { ascending: false })
  .limit(1)
  .single()

const latest = latestData as Edition | null

// Artigos da última edição
let articles: Article[] = []
if (latest) {
  const { data } = await supabase
    .from('articles')
    .select('*')
    .eq('edition_id', latest.id)
    .order('position', { ascending: true })
  articles = (data ?? []) as Article[]
}

const hero = articles[0] ?? null
const remainingArticles = articles.slice(1)
const grouped = groupByCategory(remainingArticles)
const orderedCategories = getOrderedCategories(grouped)

// Edições anteriores
const { data: archiveData } = await supabase
  .from('editions')
  .select('id, slug, edition_number, title, created_at')
  .order('edition_number', { ascending: false })
  .range(1, 5)

const recentEditions = (archiveData ?? []) as Pick<
  Edition,
  'id' | 'slug' | 'edition_number' | 'title' | 'created_at'
>[]

const today = formatFullDate(new Date())
---

<Layout>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-6xl px-6 sm:px-10 py-6 sm:py-8">

      {/* ── MASTHEAD ── */}
      <header class="mb-8">
        <div class="flex items-center justify-between pb-2 border-b border-foreground/10">
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground">
            {today}
          </p>
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground hidden sm:block">
            {SITE_TAGLINE}
          </p>
        </div>
        <div class="border-b-4 border-double border-foreground py-4 sm:py-5 text-center">
          <h1 class="font-serif text-[clamp(3.5rem,14vw,7rem)] font-black leading-[0.85] tracking-tighter uppercase">
            {SITE_NAME.toUpperCase()}
          </h1>
          <p class="font-mono text-xs tracking-[0.3em] uppercase text-muted-foreground mt-2">
            {MASTHEAD_SUBTITLE}
          </p>
        </div>
      </header>

      {latest && hero ? (
        <>
          {/* ── EDIÇÃO ATUAL ── */}
          <section class="mb-10">
            <p class="font-mono text-[0.55rem] tracking-widest uppercase text-muted-foreground mb-6 text-center">
              Edição nº {latest.edition_number} &mdash; {formatMediumDate(latest.created_at)}
            </p>

            {/* Hero */}
            <article class="text-center mb-10">
              <span class="inline-block font-mono text-[0.5rem] tracking-widest uppercase text-muted-foreground border border-foreground/20 px-2 py-0.5 mb-4">
                {hero.category}
              </span>
              <a href={`/${latest.slug}`} class="block group">
                <h2 class="font-serif text-3xl sm:text-4xl font-black leading-[1.1] tracking-tight mb-4 group-hover:opacity-60 transition-opacity">
                  {hero.title}
                </h2>
              </a>
              <p class="text-base leading-relaxed text-foreground/70 mb-3">
                {hero.summary_ptbr}
              </p>
              <p class="font-mono text-[0.55rem] text-muted-foreground">
                {hero.source}
                {hero.reading_time_min && <> &middot; {hero.reading_time_min} min de leitura</>}
              </p>
            </article>

            <div class="h-px bg-foreground/15 mb-10"></div>

            {/* Artigos restantes — empilhados */}
            {orderedCategories.map((cat, catIdx) => {
              const catArticles = grouped[cat]!
              return (
                <section class:list={[catIdx > 0 && "border-t border-foreground/15 pt-8 mt-8"]}>
                  <div class="flex items-center gap-3 mb-5">
                    <h3 class="font-mono text-[0.6rem] tracking-widest uppercase font-bold shrink-0 bg-foreground text-background px-2 py-1">
                      {cat}
                    </h3>
                    <div class="h-px flex-1 bg-foreground/15"></div>
                  </div>

                  <div class="space-y-6">
                    {catArticles.map((article) => (
                      <a href={`/${latest.slug}`} class="block group">
                        <h4 class="font-serif text-xl font-bold leading-snug group-hover:opacity-60 transition-opacity mb-2">
                          {article.title}
                        </h4>
                        <p class="text-sm text-foreground/60 line-clamp-3 leading-relaxed mb-2">
                          {article.summary_ptbr}
                        </p>
                        <p class="font-mono text-[0.5rem] text-muted-foreground">
                          {article.source}
                          {article.reading_time_min ? ` · ${article.reading_time_min} min` : ''}
                        </p>
                      </a>
                    ))}
                  </div>
                </section>
              )
            })}

            {/* Link edição completa */}
            <div class="border-y-2 border-foreground/20 py-4 mt-10 text-center">
              <a
                href={`/${latest.slug}`}
                class="font-mono text-[0.65rem] tracking-widest uppercase hover:opacity-60 transition-opacity font-bold"
              >
                Ler edição completa &rarr;
              </a>
            </div>
          </section>
        </>
      ) : (
        <section class="py-16 text-center mb-10">
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground mb-3">
            Em breve
          </p>
          <h2 class="font-serif text-4xl sm:text-5xl font-bold mb-4">
            A primeira edição chega segunda-feira.
          </h2>
          <p class="text-muted-foreground max-w-lg mx-auto">
            Inscreva-se para receber {SITE_NAME} diretamente no seu email.
          </p>
        </section>
      )}

      {/* ── SUBSCRIBE ── */}
      <section class="border-t border-foreground/15 py-10 text-center">
        <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground mb-1">
          Toda segunda-feira no seu inbox
        </p>
        <h2 class="font-serif text-2xl sm:text-3xl font-black mb-2">
          Assine o {SITE_NAME}
        </h2>
        <p class="text-sm text-muted-foreground mb-6">
          Curadoria semanal gratuita de artigos, ferramentas e tendências dev.
        </p>
        <form id="subscribe-form" class="flex flex-col sm:flex-row gap-2 max-w-xl mx-auto">
          <input
            type="email"
            name="email"
            placeholder="seu@email.com"
            required
            class="flex-1 border-2 border-foreground/20 bg-background px-4 py-3 text-sm font-mono placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
          />
          <button
            type="submit"
            class="bg-foreground text-background font-mono text-[0.6rem] tracking-widest uppercase px-8 py-3 hover:opacity-75 transition-opacity cursor-pointer font-bold"
          >
            Assinar
          </button>
        </form>
        <p id="subscribe-msg" class="mt-3 text-sm font-mono hidden"></p>
      </section>

      {/* ── EDIÇÕES ANTERIORES ── */}
      {recentEditions.length > 0 && (
        <section class="border-t border-foreground/15 pt-8 pb-4">
          <div class="flex items-center gap-3 mb-5">
            <h3 class="font-mono text-[0.6rem] tracking-widest uppercase font-bold text-foreground shrink-0">
              Edições anteriores
            </h3>
            <div class="h-px flex-1 bg-foreground/15"></div>
          </div>
          <ul class="divide-y divide-foreground/10">
            {recentEditions.map((edition) => (
              <li>
                <a
                  href={`/${edition.slug}`}
                  class="flex items-baseline justify-between py-3 hover:opacity-60 transition-opacity group"
                >
                  <span class="font-mono text-[0.55rem] text-muted-foreground mr-3 shrink-0">
                    #{formatEditionNumber(edition.edition_number)}
                  </span>
                  <span class="font-serif text-sm font-semibold flex-1 group-hover:underline underline-offset-2">
                    {edition.title}
                  </span>
                  <span class="font-mono text-[0.55rem] text-muted-foreground ml-3 shrink-0 hidden sm:inline">
                    {formatShortDate(edition.created_at)}
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <div class="mt-5 text-center">
            <a
              href="/archive"
              class="font-mono text-[0.6rem] tracking-widest uppercase border-b border-foreground/30 pb-px text-muted-foreground hover:text-foreground hover:border-foreground transition-colors"
            >
              Ver todas as edições &rarr;
            </a>
          </div>
        </section>
      )}

    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement
  const msg = document.getElementById('subscribe-msg') as HTMLParagraphElement

  const EMAIL_RE = /^[a-z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)*\.[a-z]{2,}$/

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim().toLowerCase()

    if (!email || !EMAIL_RE.test(email)) {
      msg.classList.remove('hidden')
      msg.textContent = 'Digite um email válido.'
      msg.className = 'mt-3 text-sm font-mono text-destructive'
      return
    }

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      })
      const data = await res.json()

      msg.classList.remove('hidden')
      if (res.ok) {
        msg.textContent = 'Inscrito com sucesso! Até segunda-feira.'
        msg.className = 'mt-3 text-sm font-mono text-foreground'
        form.reset()
      } else {
        msg.textContent = data.error ?? 'Erro ao inscrever. Tente novamente.'
        msg.className = 'mt-3 text-sm font-mono text-destructive'
      }
    } catch {
      msg.classList.remove('hidden')
      msg.textContent = 'Erro de conexão. Tente novamente.'
      msg.className = 'mt-3 text-sm font-mono text-destructive'
    }
  })
</script>
