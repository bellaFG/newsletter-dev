---
import Layout from '@/layouts/Layout.astro'
import { supabase } from '@/lib/supabase'
import type { Article, Edition } from '@/lib/types'
import { formatFullDate, formatMediumDate, formatShortDate, formatEditionNumber } from '@/lib/date'
import { groupByCategory, getOrderedCategories } from '@/lib/articles'
import { SITE_NAME, SITE_TAGLINE, MASTHEAD_SUBTITLE } from '@/lib/config'

// Última edição
const { data: latestData } = await supabase
  .from('editions')
  .select('*')
  .order('edition_number', { ascending: false })
  .limit(1)
  .single()

const latest = latestData as Edition | null

// Artigos da última edição
let articles: Article[] = []
if (latest) {
  const { data } = await supabase
    .from('articles')
    .select('*')
    .eq('edition_id', latest.id)
    .order('position', { ascending: true })
  articles = (data ?? []) as Article[]
}

const hero = articles[0] ?? null
const remainingArticles = articles.slice(1)
const grouped = groupByCategory(remainingArticles)
const orderedCategories = getOrderedCategories(grouped)

// Edições anteriores
const { data: archiveData } = await supabase
  .from('editions')
  .select('id, slug, edition_number, title, created_at')
  .order('edition_number', { ascending: false })
  .range(1, 5)

const recentEditions = (archiveData ?? []) as Pick<
  Edition,
  'id' | 'slug' | 'edition_number' | 'title' | 'created_at'
>[]

const today = formatFullDate(new Date())
---

<Layout>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 py-8 sm:py-10">

      {/* ── MASTHEAD ── */}
      <header class="pb-4 mb-1">
        <div class="flex items-center justify-between mb-3">
          <p class="font-mono text-[0.6rem] sm:text-[0.65rem] tracking-widest uppercase text-muted-foreground">
            {today}
          </p>
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground hidden sm:block">
            {SITE_TAGLINE}
          </p>
        </div>
        <div class="border-y-2 border-foreground/50 py-3 sm:py-4 text-center">
          <h1 class="font-serif text-[clamp(2.5rem,10vw,6rem)] font-black leading-none tracking-tighter uppercase">
            {SITE_NAME.toUpperCase()}
          </h1>
        </div>
        <div class="flex items-center gap-3 justify-center mt-3">
          <div class="h-px w-12 bg-foreground/20"></div>
          <p class="font-mono text-[0.55rem] sm:text-[0.6rem] tracking-[0.25em] uppercase text-muted-foreground">
            {MASTHEAD_SUBTITLE}
          </p>
          <div class="h-px w-12 bg-foreground/20"></div>
        </div>
      </header>

      <div class="border-t border-foreground/15 mt-2 mb-6 sm:mb-8"></div>

      {latest && hero ? (
        <>
          {/* ── EDIÇÃO ATUAL ── */}
          <div class="flex items-center gap-3 mb-5">
            <p class="font-mono text-[0.55rem] sm:text-[0.6rem] tracking-widest uppercase text-muted-foreground shrink-0">
              Edição nº {latest.edition_number} &mdash; {formatMediumDate(latest.created_at)}
            </p>
            <div class="h-px flex-1 bg-foreground/15"></div>
          </div>

          {/* ── HERO (manchete principal) ── */}
          <article class="mb-8 sm:mb-10">
            <span class="inline-block font-mono text-[0.55rem] tracking-widest uppercase text-muted-foreground border border-foreground/20 px-2 py-0.5 mb-3">
              {hero.category}
            </span>
            <a href={`/${latest.slug}`}>
              <h2 class="font-serif text-3xl sm:text-5xl font-bold leading-tight tracking-tight mb-3 hover:opacity-60 transition-opacity">
                {hero.title}
              </h2>
            </a>
            <p class="font-mono text-[0.6rem] text-muted-foreground mb-3 flex items-center gap-2">
              <span>{hero.source}</span>
              {hero.reading_time_min && (
                <>
                  <span>&middot;</span>
                  <span>{hero.reading_time_min} min de leitura</span>
                </>
              )}
            </p>
            <p class="text-base sm:text-lg leading-relaxed text-foreground/75 max-w-3xl">
              {hero.summary_ptbr}
            </p>
          </article>

          <div class="border-t border-foreground/15 mb-8 sm:mb-10"></div>

          {/* ── ARTIGOS POR CATEGORIA (layout jornal) ── */}
          {orderedCategories.length > 0 && (
            <div class="space-y-8 sm:space-y-10">
              {orderedCategories.map((cat) => {
                const catArticles = grouped[cat]!
                const isMultiple = catArticles.length > 1
                return (
                  <section>
                    {/* Cabeçalho de categoria */}
                    <div class="flex items-center gap-3 mb-5">
                      <h3 class="font-mono text-[0.65rem] sm:text-xs tracking-widest uppercase font-bold text-foreground shrink-0">
                        {cat}
                      </h3>
                      <div class="h-px flex-1 bg-foreground/15"></div>
                    </div>

                    {isMultiple ? (
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-0 divide-y sm:divide-y-0 sm:divide-x divide-foreground/10">
                        {catArticles.map((article) => (
                          <a
                            href={`/${latest.slug}`}
                            class="block group py-4 sm:py-0 sm:px-6 first:sm:pl-0 last:sm:pr-0"
                          >
                            <p class="font-mono text-[0.55rem] tracking-widest text-muted-foreground mb-1">
                              {article.source}
                              {article.reading_time_min ? ` · ${article.reading_time_min} min` : ''}
                            </p>
                            <h4 class="font-serif text-lg sm:text-xl font-semibold leading-snug group-hover:opacity-60 transition-opacity mb-2">
                              {article.title}
                            </h4>
                            <p class="text-sm text-foreground/60 line-clamp-3 leading-relaxed">
                              {article.summary_ptbr}
                            </p>
                          </a>
                        ))}
                      </div>
                    ) : (
                      <a href={`/${latest.slug}`} class="block group">
                        <p class="font-mono text-[0.55rem] tracking-widest text-muted-foreground mb-1">
                          {catArticles[0].source}
                          {catArticles[0].reading_time_min ? ` · ${catArticles[0].reading_time_min} min` : ''}
                        </p>
                        <h4 class="font-serif text-lg sm:text-xl font-semibold leading-snug group-hover:opacity-60 transition-opacity mb-2">
                          {catArticles[0].title}
                        </h4>
                        <p class="text-sm text-foreground/60 line-clamp-3 leading-relaxed max-w-2xl">
                          {catArticles[0].summary_ptbr}
                        </p>
                      </a>
                    )}
                  </section>
                )
              })}
            </div>
          )}

          {/* ── LINK EDIÇÃO COMPLETA ── */}
          <div class="border-t border-foreground/15 mt-8 sm:mt-10 pt-6 text-center">
            <a
              href={`/${latest.slug}`}
              class="font-mono text-[0.65rem] tracking-widest uppercase border-b border-foreground/40 pb-px hover:border-foreground hover:opacity-80 transition-all"
            >
              Ler edição completa &rarr;
            </a>
          </div>
        </>
      ) : (
        <div class="py-16 text-center">
          <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-3">
            Em breve
          </p>
          <h2 class="font-serif text-3xl font-bold mb-4">
            A primeira edição chega segunda-feira.
          </h2>
          <p class="text-muted-foreground max-w-sm mx-auto">
            Inscreva-se para receber {SITE_NAME} diretamente no seu email.
          </p>
        </div>
      )}

      {/* ── SUBSCRIBE ── */}
      <div class="py-10 sm:py-14 my-8 sm:my-10 text-center">
        <div class="max-w-sm mx-auto">
          <p class="font-mono text-[0.55rem] sm:text-[0.6rem] tracking-widest uppercase text-muted-foreground mb-3">
            Receba toda segunda-feira
          </p>
          <h2 class="font-serif text-xl sm:text-2xl font-bold mb-2">
            Assine o {SITE_NAME}
          </h2>
          <p class="text-sm text-muted-foreground mb-6">
            Curadoria semanal gratuita, direto no seu email.
          </p>
          <form id="subscribe-form" class="flex flex-col sm:flex-row gap-3">
            <input
              type="email"
              name="email"
              placeholder="seu@email.com"
              required
              class="flex-1 border border-foreground/20 bg-background px-4 py-3 text-sm font-mono placeholder:text-muted-foreground focus:outline-none focus:border-foreground/50 transition-colors"
            />
            <button
              type="submit"
              class="bg-foreground text-background font-mono text-[0.65rem] tracking-widest uppercase px-6 py-3 hover:opacity-75 transition-opacity cursor-pointer"
            >
              Assinar
            </button>
          </form>
          <p id="subscribe-msg" class="mt-4 text-sm font-mono hidden"></p>
        </div>
      </div>

      {/* ── EDIÇÕES ANTERIORES ── */}
      {recentEditions.length > 0 && (
        <section class="mb-10">
          <div class="flex items-center gap-3 mb-5">
            <h3 class="font-mono text-[0.65rem] sm:text-xs tracking-widest uppercase font-bold text-foreground shrink-0">
              Edições anteriores
            </h3>
            <div class="h-px flex-1 bg-foreground/15"></div>
          </div>
          <ul class="divide-y divide-foreground/10">
            {recentEditions.map((edition) => (
              <li>
                <a
                  href={`/${edition.slug}`}
                  class="flex items-baseline justify-between py-3 sm:py-4 hover:opacity-60 transition-opacity group"
                >
                  <span class="font-mono text-[0.6rem] sm:text-[0.65rem] text-muted-foreground mr-3 sm:mr-4 shrink-0">
                    #{formatEditionNumber(edition.edition_number)}
                  </span>
                  <span class="font-serif text-sm sm:text-base font-semibold flex-1 group-hover:underline underline-offset-2">
                    {edition.title}
                  </span>
                  <span class="font-mono text-[0.6rem] sm:text-[0.65rem] text-muted-foreground ml-3 sm:ml-4 shrink-0 hidden sm:inline">
                    {formatShortDate(edition.created_at)}
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <div class="mt-5 text-center">
            <a
              href="/archive"
              class="font-mono text-[0.65rem] tracking-widest uppercase border-b border-foreground/30 pb-px text-muted-foreground hover:text-foreground hover:border-foreground transition-colors"
            >
              Ver todas as edições &rarr;
            </a>
          </div>
        </section>
      )}

    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement
  const msg = document.getElementById('subscribe-msg') as HTMLParagraphElement

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const email = (form.elements.namedItem('email') as HTMLInputElement).value

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      })
      const data = await res.json()

      msg.classList.remove('hidden')
      if (res.ok) {
        msg.textContent = 'Inscrito com sucesso! Até segunda-feira.'
        msg.className = 'mt-4 text-sm font-mono text-foreground'
        form.reset()
      } else {
        msg.textContent = data.error ?? 'Erro ao inscrever. Tente novamente.'
        msg.className = 'mt-4 text-sm font-mono text-destructive'
      }
    } catch {
      msg.classList.remove('hidden')
      msg.textContent = 'Erro de conexão. Tente novamente.'
      msg.className = 'mt-4 text-sm font-mono text-destructive'
    }
  })
</script>
