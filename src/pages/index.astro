---
import Layout from '@/layouts/Layout.astro'
import { supabase } from '@/lib/supabase'
import type { Article, Edition } from '@/lib/types'
import { formatFullDate, formatMediumDate, formatShortDate, formatEditionNumber, formatRelativeTime } from '@/lib/date'
import { CATEGORY_ORDER, CATEGORY_SLUGS } from '@/lib/articles'
import { SITE_NAME, SITE_TAGLINE, MASTHEAD_SUBTITLE } from '@/lib/config'

// Última edição
const { data: latestData } = await supabase
  .from('editions')
  .select('*')
  .order('edition_number', { ascending: false })
  .limit(1)
  .single()

const latest = latestData as Edition | null

// Artigos da última edição
let articles: Article[] = []
if (latest) {
  const { data } = await supabase
    .from('articles')
    .select('*')
    .eq('edition_id', latest.id)
    .order('position', { ascending: true })
  articles = (data ?? []) as Article[]
}

// Edições anteriores
const { data: archiveData } = await supabase
  .from('editions')
  .select('id, slug, edition_number, title, created_at')
  .order('edition_number', { ascending: false })
  .range(1, 5)

const recentEditions = (archiveData ?? []) as Pick<
  Edition,
  'id' | 'slug' | 'edition_number' | 'title' | 'created_at'
>[]

const today = formatFullDate(new Date())
---

<Layout>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-6xl px-6 sm:px-10 py-6 sm:py-8">

      {/* ── MASTHEAD ── */}
      <header class="mb-6">
        <div class="flex items-center justify-between pb-2 border-b border-foreground/10">
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground">
            {today}
          </p>
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground hidden sm:block">
            {SITE_TAGLINE}
          </p>
        </div>
        <div class="border-b-4 border-double border-foreground py-4 sm:py-5 text-center">
          <h1 class="font-serif text-[clamp(3.5rem,14vw,7rem)] font-black leading-[0.85] tracking-tighter uppercase">
            {SITE_NAME.toUpperCase()}
          </h1>
          <p class="font-mono text-xs tracking-[0.3em] uppercase text-muted-foreground mt-2">
            {MASTHEAD_SUBTITLE}
          </p>
        </div>

        {/* ── CATEGORIAS (mobile: scroll horizontal, desktop: flex-wrap centralizado) ── */}
        <nav class="overflow-x-auto sm:overflow-x-visible -mx-6 px-6 sm:mx-0 sm:px-0 py-3">
          <div class="flex sm:flex-wrap sm:justify-center gap-x-4 gap-y-1.5 min-w-max sm:min-w-0 font-mono text-[0.6rem] tracking-widest uppercase">
            {CATEGORY_ORDER.map((cat, i) => (
              <>
                {i > 0 && <span class="text-foreground/20 select-none hidden sm:inline" aria-hidden="true">|</span>}
                <a
                  href={`/categoria/${CATEGORY_SLUGS[cat]}`}
                  class="text-muted-foreground hover:text-foreground transition-colors whitespace-nowrap shrink-0"
                >
                  {cat}
                </a>
              </>
            ))}
          </div>
        </nav>
        <div class="h-px bg-foreground/15"></div>
      </header>

      {/* ── SEARCH BAR ── */}
      <div class="mb-8">
        <div class="relative max-w-md mx-auto">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input
            id="search-input"
            type="text"
            placeholder="Buscar na newsletter..."
            class="w-full border border-foreground/20 bg-background px-4 py-2.5 pl-10 text-sm font-mono placeholder:text-muted-foreground focus:outline-none focus:border-foreground/40 transition-colors"
          />
        </div>
        <div id="search-results" class="hidden mt-4 max-w-2xl mx-auto space-y-2"></div>
      </div>

      {latest && articles.length > 0 ? (
        <>
          {/* ── FEATURED WEEKLY EDITION ── */}
          <section class="mb-10">
            <div class="border-2 border-foreground/15 p-8 sm:p-10">
              <div class="flex flex-wrap items-center gap-3 mb-5">
                <span class="font-mono text-[0.55rem] tracking-widest uppercase font-bold bg-foreground text-background px-2 py-1">
                  Edição #{formatEditionNumber(latest.edition_number)}
                </span>
                <span class="font-mono text-[0.55rem] tracking-widest uppercase text-link">
                  {formatMediumDate(latest.created_at)}
                </span>
                <span class="font-mono text-[0.55rem] tracking-widest uppercase text-muted-foreground">
                  Newsletter Semanal
                </span>
              </div>

              {/* Artigo destaque */}
              {articles[0] && (
                <div class="mb-5">
                  <p class="font-mono text-[0.5rem] tracking-widest uppercase text-link mb-2">
                    {articles[0].category} &middot; {articles[0].source}
                  </p>
                  <h2 class="font-serif text-2xl sm:text-3xl font-black leading-[1.15] tracking-tight mb-2">
                    {articles[0].title_ptbr ?? articles[0].title}
                  </h2>
                  <p class="text-sm leading-relaxed text-foreground/70 line-clamp-2">
                    {articles[0].summary_ptbr}
                  </p>
                </div>
              )}

              <div class="h-px bg-foreground/10 mb-5"></div>

              {/* Resumo da edição */}
              <p class="text-sm text-foreground/50 mb-5">
                + {articles.length - 1} artigos sobre {[...new Set(articles.slice(1).map(a => a.category))].slice(0, 3).join(', ')} e mais
              </p>

              <a
                href={`/${latest.slug}`}
                class="inline-block bg-link text-white font-mono text-[0.5rem] tracking-widest uppercase px-4 py-2 hover:opacity-75 transition-opacity font-bold"
              >
                Ler edicao completa &rarr;
              </a>
            </div>
          </section>

          {/* ── GRID DE CARDS ── */}
          <section class="mb-10" id="articles-grid">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="articles-container">
              {articles.map((article) => (
                <a
                  href={`/edicao/${latest.slug}/${article.slug}`}
                  class="block border border-foreground/10 p-5 hover:border-foreground/30 transition-colors group"
                  data-title={(article.title_ptbr ?? article.title).toLowerCase()}
                  data-summary={(article.summary_ptbr ?? '').toLowerCase()}
                >
                  <h3 class="font-serif text-lg font-bold leading-snug mb-2 group-hover:opacity-60 transition-opacity">
                    {article.title_ptbr ?? article.title}
                  </h3>
                  <p class="text-sm text-foreground/60 line-clamp-2 leading-relaxed mb-3">
                    {article.summary_ptbr}
                  </p>
                  <div class="flex items-center justify-between font-mono text-[0.5rem] text-muted-foreground">
                    <span class="text-link">{article.source}</span>
                    <div class="flex items-center gap-2">
                      {article.reading_time_min && <span>{article.reading_time_min} min</span>}
                      <span>{formatRelativeTime(article.created_at)}</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>

            {/* Paginacao */}
            {articles.length > 9 && (
              <div id="pagination" class="flex items-center justify-center gap-4 mt-8 font-mono text-[0.6rem] tracking-widest uppercase">
                <button id="prev-page" class="text-muted-foreground hover:text-foreground transition-colors disabled:opacity-30 disabled:cursor-default" disabled>
                  &larr; Anterior
                </button>
                <span id="page-info" class="text-muted-foreground"></span>
                <button id="next-page" class="text-link hover:opacity-70 transition-opacity disabled:opacity-30 disabled:cursor-default">
                  Proxima &rarr;
                </button>
              </div>
            )}
          </section>
        </>
      ) : (
        <section class="py-16 text-center mb-10">
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground mb-3">
            Em breve
          </p>
          <h2 class="font-serif text-4xl sm:text-5xl font-bold mb-4">
            A primeira edição chega segunda-feira.
          </h2>
          <p class="text-muted-foreground max-w-lg mx-auto">
            Inscreva-se para receber {SITE_NAME} diretamente no seu email.
          </p>
        </section>
      )}

      {/* ── EDIÇÕES ANTERIORES ── */}
      {recentEditions.length > 0 && (
        <section class="border-t border-foreground/15 pt-8 pb-4">
          <div class="flex items-center gap-3 mb-5">
            <h3 class="font-mono text-[0.6rem] tracking-widest uppercase font-bold text-foreground shrink-0">
              Edições anteriores
            </h3>
            <div class="h-px flex-1 bg-foreground/15"></div>
          </div>
          <ul class="divide-y divide-foreground/10">
            {recentEditions.map((edition) => (
              <li>
                <a
                  href={`/${edition.slug}`}
                  class="flex items-baseline justify-between py-3 hover:opacity-60 transition-opacity group"
                >
                  <span class="font-mono text-[0.55rem] text-link mr-3 shrink-0">
                    #{formatEditionNumber(edition.edition_number)}
                  </span>
                  <span class="font-serif text-sm font-semibold flex-1 group-hover:underline underline-offset-2">
                    {edition.title}
                  </span>
                  <span class="font-mono text-[0.55rem] text-link ml-3 shrink-0 hidden sm:inline">
                    {formatShortDate(edition.created_at)}
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <div class="mt-5 text-center">
            <a
              href="/archive"
              class="font-mono text-[0.6rem] tracking-widest uppercase border-b border-link/50 pb-px text-link hover:opacity-70 transition-colors"
            >
              Ver todas as edições &rarr;
            </a>
          </div>
        </section>
      )}

    </div>
  </div>
</Layout>

<script>
  const PER_PAGE = 9
  const input = document.getElementById('search-input') as HTMLInputElement | null
  const resultsContainer = document.getElementById('search-results')
  const grid = document.getElementById('articles-grid')
  const container = document.getElementById('articles-container')
  const pagination = document.getElementById('pagination')
  const prevBtn = document.getElementById('prev-page') as HTMLButtonElement | null
  const nextBtn = document.getElementById('next-page') as HTMLButtonElement | null
  const pageInfo = document.getElementById('page-info')

  if (container && grid) {
    const allCards = Array.from(container.querySelectorAll('a[data-title]')) as HTMLAnchorElement[]
    let currentPage = 1
    let visibleCards = allCards
    let isSearching = false

    function renderPage() {
      if (isSearching) {
        // Durante busca, mostra todos os resultados sem paginacao
        if (pagination) pagination.style.display = 'none'
        return
      }

      const totalPages = Math.ceil(visibleCards.length / PER_PAGE)
      const start = (currentPage - 1) * PER_PAGE
      const end = start + PER_PAGE

      allCards.forEach(card => card.style.display = 'none')
      visibleCards.forEach((card, i) => {
        card.style.display = i >= start && i < end ? '' : 'none'
      })

      if (pagination && totalPages > 1) {
        pagination.style.display = ''
        if (prevBtn) prevBtn.disabled = currentPage <= 1
        if (nextBtn) nextBtn.disabled = currentPage >= totalPages
        if (pageInfo) pageInfo.textContent = `${currentPage} / ${totalPages}`
      } else if (pagination) {
        pagination.style.display = 'none'
      }
    }

    prevBtn?.addEventListener('click', () => { currentPage--; renderPage() })
    nextBtn?.addEventListener('click', () => { currentPage++; renderPage() })

    // Paginacao inicial
    visibleCards = allCards
    renderPage()

    // Busca
    if (input && resultsContainer) {
      let debounceTimer: ReturnType<typeof setTimeout>

      input.addEventListener('input', () => {
        clearTimeout(debounceTimer)
        debounceTimer = setTimeout(() => {
          const query = input.value.trim().toLowerCase()

          if (!query) {
            isSearching = false
            visibleCards = allCards
            currentPage = 1
            renderPage()
            resultsContainer.classList.add('hidden')
            return
          }

          isSearching = true
          allCards.forEach(card => {
            const title = card.dataset.title ?? ''
            const summary = card.dataset.summary ?? ''
            const matches = title.includes(query) || summary.includes(query)
            card.style.display = matches ? '' : 'none'
          })

          const matchCount = allCards.filter(c => c.style.display !== 'none').length
          resultsContainer.innerHTML = `<p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground text-center">${matchCount} resultado${matchCount !== 1 ? 's' : ''} para "${input.value.trim()}"</p>`
          resultsContainer.classList.remove('hidden')
          if (pagination) pagination.style.display = 'none'
        }, 200)
      })
    }
  }
</script>
