---
import Layout from '@/layouts/Layout.astro'
import ArticleCard from '@/components/ArticleCard.astro'
import SectionHeader from '@/components/SectionHeader.astro'
import { supabase } from '@/lib/supabase'
import type { Article, Edition } from '@/lib/types'
import { getPrimarySource, listPublishedArticles, paginateItems } from '@/lib/articles'
import { getEditionDisplayDate, getLatestEditionWithArticles } from '@/lib/editions'
import { formatFullDate, formatMediumDate, formatEditionNumber } from '@/lib/date'
import { getPublishingStatus } from '@/lib/publishing'
import { SITE_NAME, SITE_TAGLINE, MASTHEAD_SUBTITLE } from '@/lib/config'

const latest = (await getLatestEditionWithArticles(supabase)) as Edition | null

let latestArticles: Article[] = []
if (latest) {
  const { data } = await supabase
    .from('articles')
    .select('*')
    .eq('edition_id', latest.id)
    .eq('status', 'active')
    .order('position', { ascending: true })
  latestArticles = (data ?? []) as Article[]
}

const allArticles = await listPublishedArticles(supabase)
const initialSearchQuery = Astro.url.searchParams.get('q')?.trim() ?? ''

const PER_PAGE = 9
const requestedPage = Number(Astro.url.searchParams.get('page') ?? '1')
const currentPage =
  Number.isFinite(requestedPage) && requestedPage > 0 ? Math.floor(requestedPage) : 1
const { items: paginatedArticles, page, totalPages } = paginateItems(allArticles, currentPage, PER_PAGE)
const pageHref = (value: number) => (value <= 1 ? '/' : `/?page=${value}`)

if (allArticles.length > 0 && currentPage > totalPages) {
  return new Response(null, {
    status: 302,
    headers: { Location: pageHref(totalPages) },
  })
}

const publishingStatus = getPublishingStatus(latest)
const today = formatFullDate(new Date())
const featuredArticle = latestArticles[0] ?? null
const remainingLatestArticles = latestArticles.slice(1)
const remainingCategories = [...new Set(remainingLatestArticles.map((article) => article.category))]
---

<Layout>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-6xl px-6 py-8 sm:px-10 sm:py-10">
      <header class="mb-8 sm:mb-10" data-route-fade>
        <div class="flex items-center justify-between gap-4 border-b border-foreground/10 pb-4">
          <p class="font-mono text-[0.65rem] uppercase tracking-widest text-muted-foreground">
            {today}
          </p>
          <p class="hidden font-mono text-[0.65rem] uppercase tracking-widest text-muted-foreground sm:block">
            {SITE_TAGLINE}
          </p>
        </div>

        <div class="mt-4 border-y-4 border-double border-foreground px-2 py-8 text-center sm:py-10">
          <h1 class="font-serif text-[clamp(3.5rem,14vw,7rem)] font-black uppercase leading-[0.85] tracking-tighter">
            {SITE_NAME.toUpperCase()}
          </h1>
          <p class="mt-3 font-mono text-xs uppercase tracking-[0.3em] text-muted-foreground">
            {MASTHEAD_SUBTITLE}
          </p>
        </div>
      </header>

      <section class="mb-12 sm:mb-14" data-route-fade>
        <div class="mx-auto max-w-4xl" data-home-search-root>
          <form
            method="get"
            action="/"
            class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4"
            data-home-search-form
            data-astro-reload
          >
            <label class="relative flex-1">
              <span class="sr-only">Buscar no acervo</span>
              <svg
                class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <input
                type="search"
                name="q"
                value={initialSearchQuery}
                autocomplete="off"
                enterkeyhint="search"
                placeholder="Buscar temas no acervo..."
                class="h-9 w-full border border-foreground/20 bg-background px-4 pl-11 text-sm font-mono placeholder:text-muted-foreground transition-colors focus:border-link focus:outline-none"
                data-home-search-input
              />
            </label>

            <button
              type="submit"
              class="inline-flex h-9 items-center justify-center border border-link px-5 font-mono text-[0.56rem] font-bold uppercase tracking-[0.22em] text-link transition-colors hover:bg-link hover:text-white sm:shrink-0"
            >
              Buscar
            </button>
          </form>

          <div class="mt-3 flex flex-wrap items-center justify-end gap-2">
            <p
              class="hidden font-mono text-[0.55rem] uppercase tracking-[0.2em] text-link"
              data-home-search-meta
            ></p>
          </div>

          <div
            class="scrollbar-thin mt-4 hidden max-h-[min(60vh,34rem)] space-y-3 overflow-y-auto pr-1"
            aria-live="polite"
            data-home-search-results
          ></div>
        </div>
      </section>

      {latest && latestArticles.length > 0 ? (
        <section class="mb-14 sm:mb-16" data-route-fade>
          <div class="border border-foreground/15 bg-background p-8 transition-colors duration-300 hover:border-link/30 sm:p-10">
            <div class="mb-5 flex flex-wrap items-center gap-3">
              <span class="bg-foreground px-2 py-1 font-mono text-[0.55rem] font-bold uppercase tracking-widest text-background">
                Edição #{formatEditionNumber(latest.edition_number)}
              </span>
              <span class="font-mono text-[0.55rem] uppercase tracking-widest text-link">
                {formatMediumDate(getEditionDisplayDate(latest))}
              </span>
              <span class="font-mono text-[0.55rem] uppercase tracking-widest text-muted-foreground">
                {publishingStatus.featuredLabel}
              </span>
            </div>

            {featuredArticle && (
              <div class="mb-5">
                <p class="mb-3 font-mono text-[0.5rem] uppercase tracking-widest text-link">
                  {featuredArticle.category} &middot; {getPrimarySource(featuredArticle).label}
                  {featuredArticle.source_count > 1 && ` · ${featuredArticle.source_count} fontes`}
                </p>
                <a href={`/edicao/${latest.slug}/${featuredArticle.slug}`} class="group block">
                  <h2 class="mb-3 font-serif text-2xl font-black leading-[1.15] tracking-tight transition-colors group-hover:text-link sm:text-3xl">
                    {featuredArticle.title_ptbr ?? featuredArticle.title}
                  </h2>
                </a>
                <p class="max-w-3xl text-sm leading-relaxed text-foreground/70">
                  {featuredArticle.summary_ptbr}
                </p>
              </div>
            )}

            {remainingLatestArticles.length > 0 && (
              <>
                <div class="mb-5 h-px bg-foreground/10"></div>

                <p class="mb-5 text-sm text-foreground/50">
                  + {remainingLatestArticles.length}{' '}
                  {remainingLatestArticles.length === 1 ? 'artigo' : 'artigos'} sobre{' '}
                  {remainingCategories.slice(0, 3).join(', ')}
                  {remainingCategories.length > 3 ? ' e mais' : ''}
                </p>
              </>
            )}

            <a
              href={`/edicao/${latest.slug}`}
              class="inline-block border-2 border-link px-5 py-2 font-mono text-[0.55rem] font-bold uppercase tracking-widest text-link transition-colors hover:bg-link hover:text-white"
            >
              {publishingStatus.featuredCtaLabel}
            </a>
          </div>
        </section>
      ) : allArticles.length === 0 ? (
        <section class="mb-14 py-16 text-center" data-route-fade>
          <p class="mb-3 font-mono text-[0.65rem] uppercase tracking-widest text-muted-foreground">
            {publishingStatus.isDelayed ? 'Estamos finalizando' : 'Em breve'}
          </p>
          <h2 class="mb-4 font-serif text-4xl font-bold sm:text-5xl">
            {publishingStatus.isDelayed
              ? 'A edição desta semana já devia ter saído.'
              : 'A primeira edição chega segunda-feira.'}
          </h2>
          <p class="mx-auto max-w-lg text-muted-foreground">
            {publishingStatus.isDelayed
              ? 'A automação tropeçou, mas já estamos colocando a newsletter no ar.'
              : `Inscreva-se para receber ${SITE_NAME} diretamente no seu email.`}
          </p>
        </section>
      ) : null}

      {allArticles.length > 0 && (
        <section
          class="mb-10"
          id="articles-grid"
          data-route-fade
          data-article-pagination-root
          data-article-pagination-endpoint="/api/articles"
          data-article-pagination-path="/"
          data-article-pagination-per-page={String(PER_PAGE)}
          data-article-pagination-current-page={String(page)}
          data-article-pagination-total-pages={String(totalPages)}
        >
          <SectionHeader title="Todos os artigos" />

          <div
            class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3"
            data-route-stagger
            data-article-grid
          >
            {paginatedArticles.map((article) => (
              <ArticleCard article={article} href={`/edicao/${article.editions.slug}/${article.slug}`} />
            ))}
          </div>

          {totalPages > 1 && (
            <div class="mt-8 flex items-center justify-center gap-4 font-mono text-[0.6rem] uppercase tracking-widest">
              <a
                href={pageHref(Math.max(1, page - 1))}
                class:list={[
                  'transition-colors hover:text-foreground',
                  page > 1 ? 'text-muted-foreground' : 'pointer-events-none text-muted-foreground/40',
                ]}
                data-article-page-link="prev"
                data-article-page={String(Math.max(1, page - 1))}
                data-astro-reload
                aria-disabled={page > 1 ? 'false' : 'true'}
              >
                &larr; Anterior
              </a>
              <span class="text-muted-foreground" data-article-page-indicator>{page} / {totalPages}</span>
              <a
                href={pageHref(Math.min(totalPages, page + 1))}
                class:list={[
                  'transition-opacity hover:opacity-70',
                  page < totalPages ? 'text-link' : 'pointer-events-none text-muted-foreground/40',
                ]}
                data-article-page-link="next"
                data-article-page={String(Math.min(totalPages, page + 1))}
                data-astro-reload
                aria-disabled={page < totalPages ? 'false' : 'true'}
              >
                Próxima &rarr;
              </a>
            </div>
          )}
        </section>
      )}
    </div>
  </div>
</Layout>
