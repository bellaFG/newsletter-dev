---
import Layout from '@/layouts/Layout.astro'
import CategoryNav from '@/components/CategoryNav.astro'
import ArticleCard from '@/components/ArticleCard.astro'
import SectionHeader from '@/components/SectionHeader.astro'
import { supabase } from '@/lib/supabase'
import type { Article, Edition } from '@/lib/types'
import { getPrimarySource } from '@/lib/articles'
import { getEditionDisplayDate, getLatestEditionWithArticles, listEditionsWithArticles } from '@/lib/editions'
import { formatFullDate, formatMediumDate, formatShortDate, formatEditionNumber } from '@/lib/date'
import { getPublishingStatus } from '@/lib/publishing'
import { SITE_NAME, SITE_TAGLINE, MASTHEAD_SUBTITLE } from '@/lib/config'

const latest = (await getLatestEditionWithArticles(supabase)) as Edition | null

let latestArticles: Article[] = []
if (latest) {
  const { data } = await supabase
    .from('articles')
    .select('*')
    .eq('edition_id', latest.id)
    .eq('status', 'active')
    .order('position', { ascending: true })
  latestArticles = (data ?? []) as Article[]
}

const recentEditions = (await listEditionsWithArticles(supabase, { from: 1, to: 5 })) as Pick<
  Edition,
  'id' | 'slug' | 'edition_number' | 'title' | 'published_at' | 'created_at'
>[]

const publishingStatus = getPublishingStatus(latest)
const today = formatFullDate(new Date())
const featuredArticle = latestArticles[0] ?? null
const remainingLatestArticles = latestArticles.slice(1)
const remainingCategories = [...new Set(remainingLatestArticles.map((article) => article.category))]
---

<Layout>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-6xl px-6 sm:px-10 py-6 sm:py-8">

      {/* -- MASTHEAD -- */}
      <header class="mb-6">
        <div class="flex items-center justify-between pb-2 border-b border-foreground/10">
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground">
            {today}
          </p>
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground hidden sm:block">
            {SITE_TAGLINE}
          </p>
        </div>
        <div class="border-b-4 border-double border-foreground py-4 sm:py-5 text-center">
          <h1 class="font-serif text-[clamp(3.5rem,14vw,7rem)] font-black leading-[0.85] tracking-tighter uppercase">
            {SITE_NAME.toUpperCase()}
          </h1>
          <p class="font-mono text-xs tracking-[0.3em] uppercase text-muted-foreground mt-2">
            {MASTHEAD_SUBTITLE}
          </p>
        </div>

        <CategoryNav mode="links" />
        <div class="h-px bg-foreground/15"></div>
      </header>

      {/* -- SEARCH BAR -- */}
      <div class="mb-8">
        <form method="get" action="/buscar" class="mx-auto max-w-2xl">
          <div class="relative flex items-center gap-2">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input
              id="search-input"
              name="q"
              type="text"
              placeholder="Buscar temas no acervo..."
              class="w-full border border-foreground/20 bg-background px-4 py-2.5 pl-10 text-sm font-mono placeholder:text-muted-foreground focus:outline-none focus:border-link transition-colors"
            />
            <button
              type="submit"
              class="shrink-0 border border-link px-4 py-2.5 font-mono text-[0.55rem] font-bold uppercase tracking-[0.22em] text-link transition-colors hover:bg-link hover:text-white"
            >
              Buscar
            </button>
          </div>
        </form>
        <p class="mt-3 text-center font-mono text-[0.55rem] uppercase tracking-[0.2em] text-muted-foreground">
          Resultados rápidos aqui. Busca compartilhável em <a href="/buscar" class="text-link transition-colors hover:opacity-70">/buscar</a>.
        </p>
        <div id="search-results" class="hidden mt-4 max-w-3xl mx-auto space-y-3" aria-live="polite"></div>
      </div>

      {latest && latestArticles.length > 0 ? (
        <>
          {/* -- FEATURED WEEKLY EDITION -- */}
          <section class="mb-10">
            <div class="border-2 border-foreground/15 p-8 sm:p-10">
              <div class="flex flex-wrap items-center gap-3 mb-5">
                <span class="font-mono text-[0.55rem] tracking-widest uppercase font-bold bg-foreground text-background px-2 py-1">
                  Edição #{formatEditionNumber(latest.edition_number)}
                </span>
                <span class="font-mono text-[0.55rem] tracking-widest uppercase text-link">
                  {formatMediumDate(getEditionDisplayDate(latest))}
                </span>
                <span class="font-mono text-[0.55rem] tracking-widest uppercase text-muted-foreground">
                  {publishingStatus.featuredLabel}
                </span>
              </div>

              {featuredArticle && (
                <div class="mb-5">
                  <p class="font-mono text-[0.5rem] tracking-widest uppercase text-link mb-2">
                    {featuredArticle.category} &middot; {getPrimarySource(featuredArticle).label}
                    {featuredArticle.source_count > 1 && ` · ${featuredArticle.source_count} fontes`}
                  </p>
                  <a href={`/edicao/${latest.slug}/${featuredArticle.slug}`} class="block group">
                    <h2 class="font-serif text-2xl sm:text-3xl font-black leading-[1.15] tracking-tight mb-2 group-hover:text-link transition-colors">
                      {featuredArticle.title_ptbr ?? featuredArticle.title}
                    </h2>
                  </a>
                  <p class="text-sm leading-relaxed text-foreground/70 line-clamp-2">
                    {featuredArticle.summary_ptbr}
                  </p>
                </div>
              )}

              {remainingLatestArticles.length > 0 && (
                <>
                  <div class="h-px bg-foreground/10 mb-5"></div>

                  <p class="text-sm text-foreground/50 mb-5">
                    + {remainingLatestArticles.length} {remainingLatestArticles.length === 1 ? 'artigo' : 'artigos'} sobre {remainingCategories.slice(0, 3).join(', ')}
                    {remainingCategories.length > 3 ? ' e mais' : ''}
                  </p>
                </>
              )}

              <a
                href={`/edicao/${latest.slug}`}
                class="inline-block font-mono text-[0.55rem] tracking-widest uppercase px-5 py-2.5 border-2 border-link text-link hover:bg-link hover:text-white transition-colors font-bold"
              >
                {publishingStatus.featuredCtaLabel}
              </a>
            </div>
          </section>

          {remainingLatestArticles.length > 0 && (
            <section class="mb-10" id="articles-grid">
              <SectionHeader title="Nesta edição" />
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                {remainingLatestArticles.map((article) => (
                  <ArticleCard article={article} href={`/edicao/${latest.slug}/${article.slug}`} />
                ))}
              </div>
              <div class="mt-6 text-center">
                <a
                  href="/articles"
                  class="font-mono text-[0.6rem] tracking-widest uppercase border-b border-link/50 pb-px text-link hover:opacity-70 transition-colors"
                >
                  Ver todos os artigos &rarr;
                </a>
              </div>
            </section>
          )}

          {remainingLatestArticles.length === 0 && (
            <div class="mb-10 text-center">
              <a
                href="/articles"
                class="font-mono text-[0.6rem] tracking-widest uppercase border-b border-link/50 pb-px text-link hover:opacity-70 transition-colors"
              >
                Ver todos os artigos &rarr;
              </a>
            </div>
          )}
        </>
      ) : (
        <section class="py-16 text-center mb-10">
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground mb-3">
            {publishingStatus.isDelayed ? 'Estamos finalizando' : 'Em breve'}
          </p>
          <h2 class="font-serif text-4xl sm:text-5xl font-bold mb-4">
            {publishingStatus.isDelayed
              ? 'A edição desta semana já devia ter saído.'
              : 'A primeira edição chega segunda-feira.'}
          </h2>
          <p class="text-muted-foreground max-w-lg mx-auto">
            {publishingStatus.isDelayed
              ? 'A automação tropeçou, mas já estamos colocando a newsletter no ar.'
              : `Inscreva-se para receber ${SITE_NAME} diretamente no seu email.`}
          </p>
        </section>
      )}

      {/* -- EDICOES ANTERIORES -- */}
      {recentEditions.length > 0 && (
        <section class="border-t border-foreground/15 pt-8 pb-4">
          <SectionHeader title="Edições anteriores" />
          <ul class="divide-y divide-foreground/10">
            {recentEditions.map((edition) => (
              <li>
                <a
                  href={`/edicao/${edition.slug}`}
                  class="flex items-baseline justify-between py-3 hover:opacity-60 transition-opacity group gap-x-3"
                >
                  <span class="font-mono text-[0.55rem] text-link shrink-0">
                    #{formatEditionNumber(edition.edition_number)}
                  </span>
                  <span class="font-serif text-sm font-semibold flex-1 min-w-0 group-hover:underline underline-offset-2">
                    {edition.title}
                  </span>
                  <span class="font-mono text-[0.55rem] text-link shrink-0">
                    {formatShortDate(getEditionDisplayDate(edition))}
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <div class="mt-5 text-center">
            <a
              href="/archive"
              class="font-mono text-[0.6rem] tracking-widest uppercase border-b border-link/50 pb-px text-link hover:opacity-70 transition-colors"
            >
              Ver todas as edições &rarr;
            </a>
          </div>
        </section>
      )}

    </div>
  </div>
</Layout>

<script>
  const input = document.getElementById('search-input') as HTMLInputElement | null
  const resultsContainer = document.getElementById('search-results')

  if (input && resultsContainer) {
    const searchInput = input
    const searchResultsContainer = resultsContainer
    let debounceTimer: ReturnType<typeof setTimeout>
    let lastController: AbortController | null = null
    let currentSearchPage = 1

    function escapeHtml(value: string) {
      return value.replace(/[&<>"']/g, (char: string) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      }[char] ?? char))
    }

    function formatEditionNumber(n: number) {
      return String(n).padStart(3, '0')
    }

    function renderSkeletons() {
      searchResultsContainer.innerHTML = `
        <div class="space-y-3" aria-hidden="true">
          ${Array.from({ length: 3 }).map(() => `
            <div class="border border-foreground/10 p-4 animate-pulse motion-reduce:animate-none">
              <div class="mb-3 h-3 w-32 bg-foreground/10"></div>
              <div class="mb-3 h-6 w-4/5 bg-foreground/10"></div>
              <div class="mb-2 h-4 w-full bg-foreground/10"></div>
              <div class="h-4 w-3/4 bg-foreground/10"></div>
            </div>
          `).join('')}
        </div>
      `
      searchResultsContainer.classList.remove('hidden')
      searchResultsContainer.setAttribute('aria-busy', 'true')
    }

    async function loadSearchResults(page: number) {
      const query = searchInput.value.trim().toLowerCase()

      if (!query) {
        lastController?.abort()
        searchResultsContainer.classList.add('hidden')
        searchResultsContainer.innerHTML = ''
        searchResultsContainer.setAttribute('aria-busy', 'false')
        return
      }

      lastController?.abort()
      lastController = new AbortController()
      renderSkeletons()

      try {
        const response = await fetch(
          `/api/search?q=${encodeURIComponent(query)}&page=${page}`,
          { signal: lastController.signal }
        )
        const data = await response.json()
        if (!response.ok) {
          throw new Error(typeof data?.error === 'string' ? data.error : 'Search failed')
        }

        const results = Array.isArray(data.results) ? data.results : []
        const safeQuery = escapeHtml(searchInput.value.trim())
        const safePage = Number(data.page ?? page) || page
        const hasMore = Boolean(data.hasMore)
        const hasPrevious = Boolean(data.hasPrevious)
        currentSearchPage = safePage

        if (results.length === 0) {
          const pageLabel = safePage > 1 ? ` na página ${safePage}` : ''
          searchResultsContainer.innerHTML = `
              <p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground text-center">
                Nenhum resultado${pageLabel} para "${safeQuery}"
              </p>
            `
          searchResultsContainer.classList.remove('hidden')
          searchResultsContainer.setAttribute('aria-busy', 'false')
          return
        }

        const items = results.map((result: any) => {
          const title = escapeHtml(result.title ?? '')
          const summary = escapeHtml(result.summary ?? '')
          const excerpt = escapeHtml(result.excerpt ?? '')
          const category = escapeHtml(result.category ?? '')
          const primarySource = escapeHtml(result.primarySource ?? '')
          const editionSlug = escapeHtml(result.edition?.slug ?? '')
          const editionNumber = formatEditionNumber(Number(result.edition?.edition_number ?? 0))
          const sourceLabel = Number(result.sourceCount ?? 1) > 1
            ? `${Number(result.sourceCount)} fontes`
            : primarySource

          return `
              <a
                href="/edicao/${editionSlug}/${escapeHtml(result.slug ?? '')}"
                class="block border border-foreground/10 p-4 hover:border-link/40 transition-colors"
              >
                <div class="flex flex-wrap items-center gap-2 mb-2 font-mono text-[0.55rem] tracking-widest uppercase text-muted-foreground">
                  <span class="text-link">#${editionNumber}</span>
                  <span>${category}</span>
                  <span>&middot;</span>
                  <span>${escapeHtml(sourceLabel)}</span>
                </div>
                <h3 class="font-serif text-xl font-bold leading-snug mb-2 text-foreground">${title}</h3>
                <p class="text-sm text-foreground/70 leading-relaxed mb-2">${summary}</p>
                <p class="text-sm text-foreground/55 leading-relaxed">${excerpt}</p>
              </a>
            `
        }).join('')

        const paginationMarkup = hasPrevious || hasMore
          ? `
              <div class="flex items-center justify-center gap-3 pt-2 font-mono text-[0.55rem] tracking-widest uppercase">
                <button
                  type="button"
                  data-search-page="prev"
                  class="text-muted-foreground hover:text-foreground transition-colors disabled:opacity-30 disabled:cursor-default"
                  ${hasPrevious ? '' : 'disabled'}
                >
                  &larr; Anterior
                </button>
                <span class="text-muted-foreground">Página ${safePage}</span>
                <button
                  type="button"
                  data-search-page="next"
                  class="text-link hover:opacity-70 transition-opacity disabled:opacity-30 disabled:cursor-default"
                  ${hasMore ? '' : 'disabled'}
                >
                  Próxima &rarr;
                </button>
              </div>
            `
          : ''

        searchResultsContainer.innerHTML = `
            <p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground text-center">
              ${results.length} resultado${results.length !== 1 ? 's' : ''} no acervo para "${safeQuery}"
            </p>
            ${items}
            ${paginationMarkup}
          `
        searchResultsContainer.classList.remove('hidden')
        searchResultsContainer.setAttribute('aria-busy', 'false')
      } catch (error: any) {
        if (error.name === 'AbortError') return
        searchResultsContainer.innerHTML = `
            <p class="font-mono text-[0.6rem] tracking-widest uppercase text-destructive text-center">
              ${escapeHtml(error.message || 'Falha ao buscar no acervo.')}
            </p>
          `
        searchResultsContainer.classList.remove('hidden')
        searchResultsContainer.setAttribute('aria-busy', 'false')
      }
    }

    searchResultsContainer.addEventListener('click', (event) => {
      const target = event.target
      if (!(target instanceof Element)) return

      const button = target.closest('[data-search-page]')
      if (!(button instanceof HTMLButtonElement) || button.disabled) return

      const direction = button.dataset.searchPage === 'next' ? 1 : -1
      void loadSearchResults(Math.max(1, currentSearchPage + direction))
    })

    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer)
      debounceTimer = setTimeout(() => {
        currentSearchPage = 1
        void loadSearchResults(1)
      }, 200)
    })
  }
</script>
