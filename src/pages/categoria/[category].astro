---
import Layout from '@/layouts/Layout.astro'
import PageFooterNav from '@/components/PageFooterNav.astro'
import { getEditionDisplayDate } from '@/lib/editions'
import { supabase } from '@/lib/supabase'
import type { Article, Edition } from '@/lib/types'
import { CATEGORY_ORDER, CATEGORY_SLUGS, getPrimarySource, SLUG_TO_CATEGORY } from '@/lib/articles'
import { formatShortDate, formatEditionNumber } from '@/lib/date'
import { SITE_NAME } from '@/lib/config'

const { category: categoryParam } = Astro.params

const categoryName = SLUG_TO_CATEGORY[categoryParam!]
if (!categoryName) return new Response(null, { status: 404 })

const { data: articlesData } = await supabase
  .from('articles')
  .select('*, editions!inner(slug, edition_number, title, published_at, created_at)')
  .eq('category', categoryName)
  .not('editions.published_at', 'is', null)
  .order('source_published_at', { ascending: false, nullsFirst: false })
  .order('created_at', { ascending: false })

type ArticleWithEdition = Article & {
  editions: Pick<Edition, 'slug' | 'edition_number' | 'title' | 'published_at' | 'created_at'>
}

const articles = (articlesData ?? []) as unknown as ArticleWithEdition[]
const currentCategoryIndex = CATEGORY_ORDER.indexOf(categoryName)
const previousCategory =
  CATEGORY_ORDER[(currentCategoryIndex - 1 + CATEGORY_ORDER.length) % CATEGORY_ORDER.length]
const nextCategory = CATEGORY_ORDER[(currentCategoryIndex + 1) % CATEGORY_ORDER.length]
const categoryLinks = CATEGORY_ORDER.map((category) => ({
  label: category,
  href: `/categoria/${CATEGORY_SLUGS[category]}`,
  isActive: category === categoryName,
}))
---

<Layout title={`${categoryName} — ${SITE_NAME}`} description={`Artigos sobre ${categoryName} no ${SITE_NAME}`}>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">

      <header class="mb-8">
        <h1 class="font-serif text-3xl sm:text-4xl font-black tracking-tight mb-2">
          {categoryName}
        </h1>
        <p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground">
          {articles.length} {articles.length === 1 ? 'artigo' : 'artigos'} de todas as edições
        </p>
      </header>

      <div class="border-t border-foreground/20 mb-8"></div>

      {articles.length > 0 ? (
        <div class="space-y-8">
          {articles.map((article) => (
            <article class="group">
              <a href={`/edicao/${article.editions.slug}/${article.slug}`} class="block">
                <div class="flex items-center gap-2 mb-2 font-mono text-[0.5rem]">
                  <span class="text-link">#{formatEditionNumber(article.editions.edition_number)}</span>
                  <span class="text-foreground/20">&middot;</span>
                  <span class="text-link">{formatShortDate(getEditionDisplayDate(article.editions))}</span>
                </div>
                <h2 class="font-serif text-xl font-bold leading-snug group-hover:text-link transition-colors mb-2">
                  {article.title_ptbr ?? article.title}
                </h2>
                <p class="text-sm text-foreground/60 line-clamp-2 leading-relaxed mb-2">
                  {article.summary_ptbr}
                </p>
                <p class="font-mono text-[0.5rem] text-link">
                  {getPrimarySource(article).label}
                  {article.source_count > 1 ? ` · ${article.source_count} fontes` : ''}
                  {article.reading_time_min ? ` · ${article.reading_time_min} min` : ''}
                </p>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <p class="text-center text-muted-foreground py-12">
          Nenhum artigo nesta categoria ainda.
        </p>
      )}

      <nav aria-label="Outras categorias" class="mt-12 border-t border-foreground/20 pt-8">
        <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="font-mono text-[0.55rem] uppercase tracking-[0.22em] text-link">
              Outras categorias
            </p>
            <h2 class="mt-2 font-serif text-2xl font-black tracking-tight">
              Continue explorando
            </h2>
          </div>
          <div class="grid grid-cols-2 gap-2 sm:w-auto">
            <a
              href={`/categoria/${CATEGORY_SLUGS[previousCategory]}`}
              class="inline-flex min-h-10 items-center justify-center border border-foreground/20 px-3 text-center font-mono text-[0.55rem] font-bold uppercase tracking-[0.18em] text-muted-foreground transition-colors hover:border-link hover:text-link"
            >
              ← Anterior
            </a>
            <a
              href={`/categoria/${CATEGORY_SLUGS[nextCategory]}`}
              class="inline-flex min-h-10 items-center justify-center border border-link px-3 text-center font-mono text-[0.55rem] font-bold uppercase tracking-[0.18em] text-link transition-colors hover:bg-link hover:text-background"
            >
              Próxima →
            </a>
          </div>
        </div>

        <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
          {categoryLinks.map((category) => (
            <a
              href={category.href}
              aria-current={category.isActive ? 'page' : undefined}
              class:list={[
                'min-h-12 border px-3 py-3 font-mono text-[0.55rem] uppercase tracking-[0.16em] transition-colors',
                category.isActive
                  ? 'border-link bg-link/10 text-link'
                  : 'border-foreground/15 text-muted-foreground hover:border-link hover:text-link',
              ]}
            >
              {category.label}
            </a>
          ))}
        </div>
      </nav>

      <PageFooterNav leftLabel="← Início" leftHref="/" rightHref={null} />

    </div>
  </div>
</Layout>
