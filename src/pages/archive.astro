---
import Layout from '@/layouts/Layout.astro'
import { supabase } from '@/lib/supabase'
import type { Edition } from '@/lib/types'

const { data } = await supabase
  .from('editions')
  .select('*')
  .order('edition_number', { ascending: false })

const editions = (data ?? []) as Edition[]
---

<Layout title="Arquivo — DevPulse">
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-2xl px-6 py-16">
      <!-- Nav -->
      <nav class="mb-12">
        <a
          href="/"
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          ← DevPulse
        </a>
      </nav>

      <header class="mb-12">
        <h1 class="text-3xl font-bold tracking-tight">Todas as edições</h1>
        <p class="mt-2 text-muted-foreground">
          {editions.length} {editions.length === 1 ? 'edição publicada' : 'edições publicadas'}
        </p>
      </header>

      {editions.length === 0 ? (
        <p class="text-muted-foreground">Nenhuma edição publicada ainda.</p>
      ) : (
        <ul class="space-y-3">
          {editions.map((edition) => (
            <li>
              <a
                href={`/${edition.slug}`}
                class="flex items-baseline justify-between rounded-lg border border-border px-5 py-4 transition-colors hover:bg-muted"
              >
                <span class="font-medium">{edition.title}</span>
                <span class="ml-4 shrink-0 text-sm font-mono text-muted-foreground">
                  {new Date(edition.created_at).toLocaleDateString('pt-BR', {
                    day: '2-digit',
                    month: 'short',
                    year: 'numeric',
                  })}
                </span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</Layout>
