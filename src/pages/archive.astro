---
import Layout from '@/layouts/Layout.astro'
import BrowseTabs from '@/components/BrowseTabs.astro'
import CompactMasthead from '@/components/CompactMasthead.astro'
import CategoryDivider from '@/components/CategoryDivider.astro'
import { supabase } from '@/lib/supabase'
import type { Edition } from '@/lib/types'
import { getEditionDisplayDate, listEditionsWithArticles } from '@/lib/editions'
import { formatCompactDate, formatEditionNumber } from '@/lib/date'
import { SITE_NAME } from '@/lib/config'

const editions = (await listEditionsWithArticles(supabase)) as Edition[]

const byYear = editions.reduce<Record<string, Edition[]>>((acc, e) => {
  const year = new Date(getEditionDisplayDate(e)).getFullYear().toString()
  if (!acc[year]) acc[year] = []
  acc[year].push(e)
  return acc
}, {})

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a))
---

<Layout title={`Arquivo — ${SITE_NAME}`}>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-3xl px-6 py-10">

      <CompactMasthead right="Arquivo" />
      <BrowseTabs active="editions" />

      <div class="mb-10">
        <p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground mb-3">
          {editions.length} {editions.length === 1 ? 'edição publicada' : 'edições publicadas'}
        </p>
        <h1 class="font-serif text-4xl font-bold tracking-tight">
          Todas as edições
        </h1>
      </div>

      {editions.length === 0 ? (
        <div class="py-16 text-center border-y border-border">
          <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-3">
            Em breve
          </p>
          <p class="font-serif text-2xl font-bold">Nenhuma edição publicada ainda.</p>
        </div>
      ) : (
        <div class="space-y-10">
          {years.map((year) => (
            <section>
              <CategoryDivider label={year} />

              <ul class="divide-y divide-border">
                {byYear[year].map((edition) => (
                  <li>
                    <a
                      href={`/edicao/${edition.slug}`}
                      class="flex flex-wrap sm:flex-nowrap items-baseline justify-between py-4 group hover:opacity-60 transition-opacity gap-x-3"
                    >
                      <span class="font-mono text-[0.65rem] text-link shrink-0">
                        #{formatEditionNumber(edition.edition_number)}
                      </span>
                      <span class="font-serif text-base font-semibold flex-1 min-w-0 group-hover:underline underline-offset-2">
                        {edition.title}
                      </span>
                      <span class="font-mono text-[0.65rem] text-link shrink-0">
                        {formatCompactDate(getEditionDisplayDate(edition))}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      )}

    </div>
  </div>
</Layout>
