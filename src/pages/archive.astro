---
import Layout from '@/layouts/Layout.astro'
import { supabase } from '@/lib/supabase'
import type { Edition } from '@/lib/types'
import { formatCompactDate, formatEditionNumber } from '@/lib/date'
import { SITE_NAME } from '@/lib/config'

const { data } = await supabase
  .from('editions')
  .select('*')
  .order('edition_number', { ascending: false })

const editions = (data ?? []) as Edition[]

// Agrupa edições por ano
const byYear = editions.reduce<Record<string, Edition[]>>((acc, e) => {
  const year = new Date(e.created_at).getFullYear().toString()
  if (!acc[year]) acc[year] = []
  acc[year].push(e)
  return acc
}, {})

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a))
---

<Layout title={`Arquivo — ${SITE_NAME}`}>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-3xl px-6 py-10">

      {/* ── MASTHEAD COMPACTO ── */}
      <header class="border-b border-foreground/30 pb-4 mb-8">
        <div class="flex items-baseline justify-between">
          <a
            href="/"
            class="font-serif text-2xl font-black tracking-tighter uppercase hover:opacity-60 transition-opacity"
          >
            {SITE_NAME.toUpperCase()}
          </a>
          <span class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground">
            Arquivo
          </span>
        </div>
      </header>

      {/* ── CABEÇALHO ── */}
      <div class="mb-10">
        <p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground mb-3">
          {editions.length} {editions.length === 1 ? 'edição publicada' : 'edições publicadas'}
        </p>
        <h1 class="font-serif text-4xl font-bold tracking-tight">
          Todas as edições
        </h1>
      </div>

      {editions.length === 0 ? (
        <div class="py-16 text-center border-y border-border">
          <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-3">
            Em breve
          </p>
          <p class="font-serif text-2xl font-bold">Nenhuma edição publicada ainda.</p>
        </div>
      ) : (
        <div class="space-y-10">
          {years.map((year) => (
            <section>
              {/* Divisor de ano */}
              <div class="flex items-center gap-3 mb-5">
                <div class="h-px flex-1 bg-foreground/20"></div>
                <p class="font-mono text-[0.6rem] tracking-[0.25em] uppercase font-bold text-foreground/70 shrink-0 px-2">
                  {year}
                </p>
                <div class="h-px flex-1 bg-foreground/20"></div>
              </div>

              <ul class="divide-y divide-border">
                {byYear[year].map((edition) => (
                  <li>
                    <a
                      href={`/${edition.slug}`}
                      class="flex items-baseline justify-between py-4 group hover:opacity-60 transition-opacity"
                    >
                      <span class="font-mono text-[0.65rem] text-muted-foreground mr-4 shrink-0">
                        #{formatEditionNumber(edition.edition_number)}
                      </span>
                      <span class="font-serif text-base font-semibold flex-1 group-hover:underline underline-offset-2">
                        {edition.title}
                      </span>
                      <span class="font-mono text-[0.65rem] text-muted-foreground ml-4 shrink-0">
                        {formatCompactDate(edition.created_at)}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      )}

      {/* ── SUBSCRIBE STRIP ── */}
      <div class="border-t border-foreground/20 pt-8 mt-12 text-center">
        <p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground mb-3">
          Ainda não assinou?
        </p>
        <a
          href="/"
          class="font-serif text-xl font-bold hover:opacity-60 transition-opacity"
        >
          Receba {SITE_NAME} toda segunda-feira &rarr;
        </a>
      </div>

    </div>
  </div>
</Layout>
