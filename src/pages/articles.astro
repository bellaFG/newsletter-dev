---
import Layout from '@/layouts/Layout.astro'
import ArticleCard from '@/components/ArticleCard.astro'
import PageFooterNav from '@/components/PageFooterNav.astro'
import { listPublishedArticles, paginateItems } from '@/lib/articles'
import { ARTICLE_LIST_PER_PAGE, normalizePositiveInteger } from '@/lib/pagination'
import { supabase } from '@/lib/supabase'
import { PUBLISH_SCHEDULE_LABEL, SITE_NAME } from '@/lib/config'

const articles = await listPublishedArticles(supabase)

const requestedPage = Number(Astro.url.searchParams.get('page') ?? '1')
const currentPage = normalizePositiveInteger(requestedPage, 1)
const { items: paginatedArticles, page, totalPages } = paginateItems(
  articles,
  currentPage,
  ARTICLE_LIST_PER_PAGE,
)
const pageHref = (value: number) => (value <= 1 ? '/articles' : `/articles?page=${value}`)

if (articles.length > 0 && currentPage > totalPages) {
  return new Response(null, {
    status: 302,
    headers: { Location: pageHref(totalPages) },
  })
}

---

<Layout
  title={`Artigos — ${SITE_NAME}`}
  description={`Todos os artigos publicados no ${SITE_NAME}.`}
  canonicalUrl={pageHref(page)}
>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-10">

      <div class="mb-12 sm:mb-14" data-route-fade>
        <p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground mb-3">
          {articles.length} {articles.length === 1 ? 'artigo publicado' : 'artigos publicados'}
        </p>
        <h1 class="font-serif text-4xl font-bold tracking-tight">
          Todos os artigos
        </h1>
        {articles.length > 0 && totalPages > 1 && (
          <p
            class="mt-3 font-mono text-[0.55rem] uppercase tracking-[0.2em] text-muted-foreground"
            data-article-page-summary
          >
            Página {page} de {totalPages}
          </p>
        )}
      </div>

      {articles.length > 0 ? (
        <section
          class="mb-10"
          data-route-fade
          data-article-pagination-root
          data-article-pagination-endpoint="/api/articles"
          data-article-pagination-path="/articles"
          data-article-pagination-per-page={String(ARTICLE_LIST_PER_PAGE)}
          data-article-pagination-current-page={String(page)}
          data-article-pagination-total-pages={String(totalPages)}
        >
          <div
            class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3"
            data-route-stagger
            data-article-grid
          >
            {paginatedArticles.map((article) => (
              <ArticleCard article={article} href={`/edicao/${article.editions.slug}/${article.slug}`} />
            ))}
          </div>

          {totalPages > 1 && (
            <div class="mt-8 flex flex-wrap items-center justify-center gap-3 font-mono text-[0.6rem] tracking-widest uppercase sm:gap-4">
              <a
                href={pageHref(Math.max(1, page - 1))}
                class:list={[
                  'transition-colors hover:text-foreground',
                  page > 1 ? 'text-muted-foreground' : 'pointer-events-none text-muted-foreground/40',
                ]}
                data-article-page-link="prev"
                data-article-page={String(Math.max(1, page - 1))}
                data-astro-reload
                aria-disabled={page > 1 ? 'false' : 'true'}
              >
                &larr; Anterior
              </a>
              <span class="text-muted-foreground" data-article-page-indicator>{page} / {totalPages}</span>
              <a
                href={pageHref(Math.min(totalPages, page + 1))}
                class:list={[
                  'transition-opacity hover:opacity-70',
                  page < totalPages ? 'text-link' : 'pointer-events-none text-muted-foreground/40',
                ]}
                data-article-page-link="next"
                data-article-page={String(Math.min(totalPages, page + 1))}
                data-astro-reload
                aria-disabled={page < totalPages ? 'false' : 'true'}
              >
                Próxima &rarr;
              </a>
            </div>
          )}
        </section>
      ) : (
        <div class="py-16 text-center border-y border-border mb-10">
          <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-3">
            Em breve
          </p>
          <p class="font-serif text-2xl font-bold">Os artigos do {SITE_NAME} aparecem aqui.</p>
          <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-muted-foreground">
            Sua newsletter sobre tecnologia, para devs brasileiros. Toda {PUBLISH_SCHEDULE_LABEL} no seu email.
          </p>
        </div>
      )}

      <PageFooterNav leftLabel="← Início" leftHref="/" rightLabel="Edições →" rightHref="/archive" />

    </div>
  </div>
</Layout>
