---
import Layout from '@/layouts/Layout.astro'
import { supabase } from '@/lib/supabase'
import type { Article, Edition } from '@/lib/types'
import { groupByCategory, getOrderedCategories } from '@/lib/articles'
import { formatFullDate, formatEditionNumber } from '@/lib/date'
import { SITE_NAME } from '@/lib/config'

const { slug } = Astro.params

const { data: editionData } = await supabase
  .from('editions')
  .select('*')
  .eq('slug', slug!)
  .single()

const edition = editionData as Edition | null

if (!edition) {
  return new Response(null, { status: 404 })
}

const { data: articlesData } = await supabase
  .from('articles')
  .select('*')
  .eq('edition_id', edition.id)
  .order('position', { ascending: true })

const articles = (articlesData ?? []) as Article[]

const grouped = groupByCategory(articles)
const orderedCategories = getOrderedCategories(grouped)
---

<Layout title={`${edition.title} — ${SITE_NAME}`} description={edition.summary ?? undefined}>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-3xl px-6 py-10">

      {/* ── MASTHEAD COMPACTO ── */}
      <header class="border-b border-foreground/30 pb-4 mb-8">
        <div class="grid grid-cols-3 items-baseline">
          <p class="font-mono text-[0.65rem] tracking-widest uppercase text-link text-left">
            {formatFullDate(edition.created_at)}
          </p>
          <a
            href="/"
            class="font-serif text-2xl font-black tracking-tighter uppercase hover:opacity-60 transition-opacity text-center"
          >
            {SITE_NAME.toUpperCase()}
          </a>
          <span class="font-mono text-[0.65rem] tracking-widest uppercase text-link text-right">
            Edição #{formatEditionNumber(edition.edition_number)}
          </span>
        </div>
      </header>

      {/* ── RESUMO DA EDIÇÃO ── */}
      {edition.summary && (
        <div class="mb-10">
          <p class="text-muted-foreground leading-relaxed text-lg">
            {edition.summary}
          </p>
        </div>
      )}

      <div class="border-t border-foreground/20 mb-10"></div>

      {/* ── ARTIGOS POR CATEGORIA ── */}
      <main>
        {orderedCategories.map((cat) => (
          <section class="mb-12 border-b border-foreground/8 pb-12 last:border-b-0 last:pb-0">
            {/* Divisor de categoria estilo jornal */}
            <div class="flex items-center gap-3 mb-7">
              <div class="h-px flex-1 bg-foreground/20"></div>
              <p class="font-mono text-[0.6rem] tracking-[0.25em] uppercase font-bold text-foreground/70 shrink-0 px-2">
                {cat}
              </p>
              <div class="h-px flex-1 bg-foreground/20"></div>
            </div>

            <div class="space-y-10">
              {grouped[cat]!.map((article) => (
                <article>
                  <div class="mb-2 flex items-center gap-2 font-mono text-[0.65rem] text-link">
                    <span class="tracking-widest">{article.source}</span>
                    {article.reading_time_min && (
                      <>
                        <span class="text-foreground/40">&middot;</span>
                        <span>{article.reading_time_min} min de leitura</span>
                      </>
                    )}
                  </div>
                  <h2 class="font-serif text-2xl sm:text-3xl font-bold leading-snug mb-3">
                    {article.title_ptbr ?? article.title}
                  </h2>
                  <p class="leading-relaxed text-foreground/80 mb-4">
                    {article.summary_ptbr}
                  </p>
                  <a
                    href={article.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-mono text-[0.65rem] tracking-widest uppercase text-link hover:opacity-60 transition-opacity"
                  >
                    Leia o artigo completo &rarr;
                  </a>
                </article>
              ))}
            </div>
          </section>
        ))}
      </main>

      {/* ── RODAPÉ ── */}
      <footer class="border-t border-foreground/20 pt-8 mt-4 flex items-center justify-between">
        <a
          href="/"
          class="font-mono text-[0.65rem] tracking-widest uppercase text-link hover:opacity-70 transition-colors"
        >
          &larr; Início
        </a>
        <a
          href="/archive"
          class="font-mono text-[0.65rem] tracking-widest uppercase text-link hover:opacity-70 transition-colors"
        >
          Todas as edições &rarr;
        </a>
      </footer>

    </div>
  </div>
</Layout>
