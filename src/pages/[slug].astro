---
import Layout from '@/layouts/Layout.astro'
import { supabase } from '@/lib/supabase'
import type { Article, ArticleCategory, Edition } from '@/lib/types'

const CATEGORY_ORDER: ArticleCategory[] = [
  'IA & Machine Learning',
  'Backend',
  'Frontend',
  'DevOps & Cloud',
  'Linguagens & Frameworks',
  'Ferramentas & Produtividade',
  'Open Source',
  'Segurança',
  'Carreira & Cultura',
]

const { slug } = Astro.params

const { data: editionData } = await supabase
  .from('editions')
  .select('*')
  .eq('slug', slug!)
  .single()

const edition = editionData as Edition | null

if (!edition) {
  return Astro.redirect('/404')
}

const { data: articlesData } = await supabase
  .from('articles')
  .select('*')
  .eq('edition_id', edition.id)
  .order('position', { ascending: true })

const articles = (articlesData ?? []) as Article[]

// Agrupa artigos por categoria na ordem editorial
const grouped = articles.reduce<Partial<Record<ArticleCategory, Article[]>>>((acc, a) => {
  if (!acc[a.category]) acc[a.category] = []
  acc[a.category]!.push(a)
  return acc
}, {})

const orderedCategories = CATEGORY_ORDER.filter((c) => grouped[c]?.length)
---

<Layout title={`${edition.title} — DevPulse`} description={edition.summary ?? undefined}>
  <div class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-3xl px-6 py-10">

      {/* ── MASTHEAD COMPACTO ── */}
      <header class="border-b-2 border-foreground pb-4 mb-8">
        <div class="flex items-baseline justify-between">
          <a
            href="/"
            class="font-serif text-2xl font-black tracking-tighter uppercase hover:opacity-60 transition-opacity"
          >
            DEVPULSE
          </a>
          <span class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground">
            Edição #{String(edition.edition_number).padStart(3, '0')}
          </span>
        </div>
      </header>

      {/* ── CABEÇALHO DA EDIÇÃO ── */}
      <div class="mb-10">
        <p class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground mb-3">
          {new Date(edition.created_at).toLocaleDateString('pt-BR', {
            weekday: 'long',
            day: 'numeric',
            month: 'long',
            year: 'numeric',
          })}
        </p>
        <h1 class="font-serif text-4xl sm:text-5xl font-bold leading-tight tracking-tight mb-4">
          {edition.title}
        </h1>
        {edition.summary && (
          <p class="text-muted-foreground leading-relaxed text-lg">
            {edition.summary}
          </p>
        )}
      </div>

      <div class="border-t-2 border-foreground mb-10"></div>

      {/* ── ARTIGOS POR CATEGORIA ── */}
      <main>
        {orderedCategories.map((cat) => (
          <section class="mb-12">
            {/* Divisor de categoria estilo jornal */}
            <div class="flex items-center gap-3 mb-7">
              <div class="h-px flex-1 bg-foreground"></div>
              <p class="font-mono text-[0.6rem] tracking-[0.25em] uppercase font-bold text-foreground shrink-0 px-2">
                {cat}
              </p>
              <div class="h-px flex-1 bg-foreground"></div>
            </div>

            <div class="space-y-10">
              {grouped[cat]!.map((article) => (
                <article>
                  <div class="mb-2 flex items-center gap-2 font-mono text-[0.65rem] text-muted-foreground">
                    <span class="tracking-widest">{article.source}</span>
                    {article.reading_time_min && (
                      <>
                        <span>&middot;</span>
                        <span>{article.reading_time_min} min de leitura</span>
                      </>
                    )}
                  </div>
                  <h2 class="font-serif text-2xl sm:text-3xl font-bold leading-snug mb-3">
                    {article.title}
                  </h2>
                  <p class="leading-relaxed text-foreground/80 mb-4">
                    {article.summary_ptbr}
                  </p>
                  <a
                    href={article.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-mono text-[0.65rem] tracking-widest uppercase border-b border-foreground pb-px hover:opacity-60 transition-opacity"
                  >
                    Leia o artigo completo &rarr;
                  </a>
                </article>
              ))}
            </div>
          </section>
        ))}
      </main>

      {/* ── RODAPÉ ── */}
      <footer class="border-t-2 border-foreground pt-8 mt-4 flex items-center justify-between">
        <a
          href="/"
          class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground hover:text-foreground transition-colors"
        >
          &larr; Início
        </a>
        <a
          href="/archive"
          class="font-mono text-[0.65rem] tracking-widest uppercase text-muted-foreground hover:text-foreground transition-colors"
        >
          Todas as edições &rarr;
        </a>
      </footer>

    </div>
  </div>
</Layout>
