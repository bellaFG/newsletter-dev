---
import Layout from '@/layouts/Layout.astro'
import { SITE_NAME } from '@/lib/config'
import { formatEditionNumber } from '@/lib/date'
import { getEditionDisplayDate, listEditionsWithArticles } from '@/lib/editions'
import { supabase } from '@/lib/supabase'
import type { Edition } from '@/lib/types'

const latestEditions = (await listEditionsWithArticles(supabase, { from: 0, to: 2 })) as Pick<
  Edition,
  'slug' | 'edition_number' | 'title' | 'published_at' | 'created_at'
>[]
---

<Layout title={`Página não encontrada — ${SITE_NAME}`}>
  <div class="min-h-screen bg-background text-foreground flex flex-col">
    <div class="mx-auto w-full max-w-3xl px-4 py-16 sm:px-6">
      <header class="border-b border-foreground/30 pb-4 mb-12">
        <a
          href="/"
          class="font-serif text-2xl font-black tracking-tighter uppercase hover:opacity-70 transition-opacity"
        >
          {SITE_NAME.toUpperCase()}
        </a>
      </header>

      <div class="py-12">
        <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-4 text-center">
          Erro 404
        </p>
        <h1 class="font-serif text-3xl sm:text-4xl font-bold mb-4 text-center">
          A página não foi encontrada.
        </h1>
        <p class="text-muted-foreground leading-relaxed mb-10 max-w-xl mx-auto text-center">
          O endereço pode ter mudado, o link pode estar quebrado ou você pode ter caído em uma rota antiga do acervo.
        </p>

        <div class="grid gap-4 sm:grid-cols-3">
          <a
            href="/"
            class="border border-link/30 px-4 py-3 text-center font-mono text-[0.58rem] uppercase tracking-[0.2em] text-link transition-colors hover:bg-link hover:text-white"
          >
            Voltar ao início
          </a>
          <a
            href="/articles"
            class="border border-foreground/15 px-4 py-3 text-center font-mono text-[0.58rem] uppercase tracking-[0.2em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
          >
            Explorar artigos
          </a>
          <a
            href="/archive"
            class="border border-foreground/15 px-4 py-3 text-center font-mono text-[0.58rem] uppercase tracking-[0.2em] text-muted-foreground transition-colors hover:border-foreground hover:text-foreground"
          >
            Ver edições
          </a>
        </div>

        {latestEditions.length > 0 && (
          <section class="mt-12 border-t border-foreground/15 pt-8">
            <p class="font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground mb-4">
              Últimas edições publicadas
            </p>

            <div class="space-y-4">
              {latestEditions.map((edition) => (
                <a
                  href={`/edicao/${edition.slug}`}
                  class="block border border-foreground/10 p-4 transition-colors hover:border-link/35"
                >
                  <div class="mb-2 flex items-center justify-between gap-3 font-mono text-[0.55rem] uppercase tracking-widest text-muted-foreground">
                    <span class="text-link">#{formatEditionNumber(edition.edition_number)}</span>
                    <span>{new Date(getEditionDisplayDate(edition)).toLocaleDateString('pt-BR')}</span>
                  </div>
                  <h2 class="font-serif text-xl font-bold leading-snug">
                    {edition.title}
                  </h2>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </div>
</Layout>
