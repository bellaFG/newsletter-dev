---
import Layout from '@/layouts/Layout.astro'
import { createServiceClient } from '@/lib/supabase'

const email = Astro.url.searchParams.get('email') ?? ''
let success = false
let message = ''

if (!email) {
  message = 'Link inválido. Verifique o email que você recebeu.'
} else {
  const supabase = createServiceClient()
  const { error } = await supabase
    .from('subscribers')
    .update({ active: false })
    .eq('email', email)

  if (error) {
    message = 'Não foi possível processar sua solicitação. Tente novamente ou entre em contato.'
  } else {
    success = true
    message = `${email} foi removido da lista. Você não receberá mais o DevPulse.`
  }
}
---

<Layout title="Cancelar inscrição — DevPulse">
  <div class="min-h-screen bg-background text-foreground flex flex-col">
    <div class="mx-auto max-w-2xl px-6 py-16 w-full">
      <!-- Masthead compacto -->
      <header class="border-b-2 border-foreground pb-4 mb-12">
        <a
          href="/"
          class="font-serif text-2xl font-black tracking-tighter uppercase hover:opacity-70 transition-opacity"
        >
          DEVPULSE
        </a>
      </header>

      <div class="text-center py-12">
        {success ? (
          <>
            <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-4">
              Inscrição cancelada
            </p>
            <h1 class="font-serif text-3xl font-bold mb-4">
              Até a próxima.
            </h1>
            <p class="text-muted-foreground leading-relaxed mb-8 max-w-sm mx-auto">
              {message}
            </p>
          </>
        ) : (
          <>
            <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-4">
              Algo deu errado
            </p>
            <h1 class="font-serif text-3xl font-bold mb-4">
              Não foi possível processar.
            </h1>
            <p class="text-muted-foreground leading-relaxed mb-8 max-w-sm mx-auto">
              {message}
            </p>
          </>
        )}
        <a
          href="/"
          class="font-mono text-xs tracking-widest uppercase border-b border-foreground pb-0.5 hover:opacity-60 transition-opacity"
        >
          Voltar ao início →
        </a>
      </div>
    </div>
  </div>
</Layout>
