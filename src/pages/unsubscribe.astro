---
import Layout from '@/layouts/Layout.astro'
import { SITE_NAME } from '@/lib/config'
import { readUnsubscribeTokenDetails } from '@/lib/unsubscribe'

const token = Astro.url.searchParams.get('token')?.trim() ?? ''
const status = Astro.url.searchParams.get('status') ?? ''
const tokenDetails = token
  ? readUnsubscribeTokenDetails(token)
  : { email: null, expired: false, version: null }
const hasValidToken = Boolean(tokenDetails.email)
---

<Layout title={`Cancelar inscrição — ${SITE_NAME}`}>
  <div class="min-h-screen bg-background text-foreground flex flex-col">
    <div class="mx-auto max-w-2xl px-6 py-16 w-full">
      <header class="border-b border-foreground/30 pb-4 mb-12">
        <a
          href="/"
          class="font-serif text-2xl font-black tracking-tighter uppercase hover:opacity-70 transition-opacity"
        >
          {SITE_NAME.toUpperCase()}
        </a>
      </header>

      <div class="text-center py-12">
        {status === 'success' ? (
          <>
            <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-4">
              Inscrição cancelada
            </p>
            <h1 class="font-serif text-3xl font-bold mb-4">
              Até a próxima.
            </h1>
            <p class="text-muted-foreground leading-relaxed mb-8 max-w-sm mx-auto">
              Sua inscrição foi removida com sucesso. Você não receberá mais o {SITE_NAME}.
            </p>
          </>
        ) : hasValidToken ? (
          <>
            <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-4">
              Confirmar cancelamento
            </p>
            <h1 class="font-serif text-3xl font-bold mb-4">
              Deseja sair da lista?
            </h1>
            <p class="text-muted-foreground leading-relaxed mb-8 max-w-sm mx-auto">
              Se você confirmar, vamos interromper os próximos envios da newsletter.
            </p>
            <form method="post" action="/api/unsubscribe" class="mb-8" data-astro-reload>
              <input type="hidden" name="token" value={token} />
              <button
                type="submit"
                class="border-2 border-link px-5 py-2.5 font-mono text-[0.58rem] uppercase tracking-widest text-link transition-colors hover:bg-link hover:text-white"
              >
                Confirmar cancelamento
              </button>
            </form>
          </>
        ) : (
          <>
            <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-4">
              Algo deu errado
            </p>
            <h1 class="font-serif text-3xl font-bold mb-4">
              Não foi possível processar.
            </h1>
            <p class="text-muted-foreground leading-relaxed mb-8 max-w-sm mx-auto">
              {status === 'error'
                ? 'Não foi possível processar sua solicitação agora. Tente novamente em alguns instantes.'
                : status === 'rate_limit'
                  ? 'Recebemos tentativas demais em sequência. Aguarde um pouco antes de tentar novamente.'
                  : status === 'expired' || tokenDetails.expired
                    ? 'Este link expirou. Use o email mais recente que você recebeu para gerar um novo cancelamento.'
                : 'Este link é inválido ou expirou. Verifique o email recebido e tente novamente.'}
            </p>
          </>
        )}
        <a
          href="/"
          class="font-mono text-xs tracking-widest uppercase border-b border-link pb-0.5 text-link hover:opacity-60 transition-opacity"
        >
          Voltar ao início →
        </a>
      </div>
    </div>
  </div>
</Layout>
