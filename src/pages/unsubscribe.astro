---
import Layout from '@/layouts/Layout.astro'
import { createServerClient } from '@/lib/supabase'
import { SITE_NAME } from '@/lib/config'

const email = Astro.url.searchParams.get('email') ?? ''
let success = false
let message = ''

// Valida formato do email (mesma regex usada no subscribe)
const isValidEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)

if (!email || !isValidEmail) {
  message = 'Link inv\u00e1lido. Verifique o email que voc\u00ea recebeu.'
} else {
  const supabase = createServerClient()
  const { error } = await supabase
    .from('subscribers')
    .update({ active: false })
    .eq('email', email)

  if (error) {
    message = 'N\u00e3o foi poss\u00edvel processar sua solicita\u00e7\u00e3o. Tente novamente ou entre em contato.'
  } else {
    success = true
    message = `${email} foi removido da lista. Voc\u00ea n\u00e3o receber\u00e1 mais o ${SITE_NAME}.`
  }
}

// Nota de seguranca: o link de unsubscribe usa o email diretamente na URL.
// Qualquer pessoa com o email pode cancelar a inscricao de outro usuario.
// Para maior seguranca, considerar HMAC-signed tokens no futuro.
---

<Layout title={`Cancelar inscri\u00e7\u00e3o \u2014 ${SITE_NAME}`}>
  <div class="min-h-screen bg-background text-foreground flex flex-col">
    <div class="mx-auto max-w-2xl px-6 py-16 w-full">
      <!-- Masthead compacto -->
      <header class="border-b-2 border-foreground pb-4 mb-12">
        <a
          href="/"
          class="font-serif text-2xl font-black tracking-tighter uppercase hover:opacity-70 transition-opacity"
        >
          {SITE_NAME.toUpperCase()}
        </a>
      </header>

      <div class="text-center py-12">
        {success ? (
          <>
            <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-4">
              Inscri\u00e7\u00e3o cancelada
            </p>
            <h1 class="font-serif text-3xl font-bold mb-4">
              At\u00e9 a pr\u00f3xima.
            </h1>
            <p class="text-muted-foreground leading-relaxed mb-8 max-w-sm mx-auto">
              {message}
            </p>
          </>
        ) : (
          <>
            <p class="font-mono text-xs tracking-widest uppercase text-muted-foreground mb-4">
              Algo deu errado
            </p>
            <h1 class="font-serif text-3xl font-bold mb-4">
              N\u00e3o foi poss\u00edvel processar.
            </h1>
            <p class="text-muted-foreground leading-relaxed mb-8 max-w-sm mx-auto">
              {message}
            </p>
          </>
        )}
        <a
          href="/"
          class="font-mono text-xs tracking-widest uppercase border-b border-foreground pb-0.5 hover:opacity-60 transition-opacity"
        >
          Voltar ao in\u00edcio \u2192
        </a>
      </div>
    </div>
  </div>
</Layout>
