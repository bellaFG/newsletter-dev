---
import '@/styles/globals.css'
import { SITE_NAME, SITE_TITLE, SITE_DESCRIPTION } from '@/lib/config'

interface Props {
  title?: string
  description?: string
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
} = Astro.props
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&display=swap"
      rel="stylesheet"
    />
    <!-- Anti-FOUC: aplica tema antes do render -->
    <script is:inline>
      // Deve corresponder a THEME_STORAGE_KEY em lib/config.ts
      ;(function () {
        const saved = localStorage.getItem('devpulse-theme')
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark')
        }
      })()
    </script>
  </head>
  <body class="antialiased">
    <!-- Header global com botao assinar -->
    <header class="fixed top-0 left-0 right-0 z-40 bg-background/95 backdrop-blur-sm border-b border-foreground/10">
      <div class="mx-auto max-w-6xl px-6 sm:px-10 flex items-center justify-between h-10">
        <a href="/" class="font-serif text-sm font-black tracking-tight uppercase hover:opacity-60 transition-opacity">
          {SITE_NAME}
        </a>
        <button
          id="subscribe-open-btn"
          class="font-mono text-[0.55rem] tracking-widest uppercase border border-link text-link px-3 py-1 hover:bg-link hover:text-background transition-colors cursor-pointer font-bold"
        >
          Assinar
        </button>
      </div>
    </header>

    <!-- Spacer para compensar o header fixo -->
    <div class="h-10"></div>

    <slot />

    <!-- Modal de assinatura -->
    <div id="subscribe-modal" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <!-- Overlay -->
      <div id="subscribe-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
      <!-- Card -->
      <div class="flex items-center justify-center min-h-full p-4">
        <div id="subscribe-card" class="relative bg-background border-2 border-foreground/20 w-full max-w-md p-8 sm:p-10 translate-y-4 opacity-0 transition-all duration-300">
          <!-- Fechar -->
          <button id="subscribe-close-btn" class="absolute top-4 right-4 font-mono text-xs text-muted-foreground hover:text-foreground transition-colors cursor-pointer" aria-label="Fechar">
            &times;
          </button>

          <!-- Conteudo do form -->
          <div id="subscribe-form-content">
            <div class="text-center mb-6">
              <div class="border-b-2 border-double border-foreground/30 pb-3 mb-4">
                <p id="modal-title" class="font-serif text-2xl sm:text-3xl font-black tracking-tight uppercase">
                  {SITE_NAME}
                </p>
              </div>
              <p class="text-sm leading-relaxed text-foreground/70">
                Receba toda segunda-feira uma curadoria dos melhores artigos, ferramentas e tendencias dev, traduzida e resumida em portugues.
              </p>
            </div>

            <form id="subscribe-form" class="space-y-3">
              <input
                type="email"
                name="email"
                placeholder="seu@email.com"
                required
                class="w-full border-2 border-foreground/20 bg-background px-4 py-3 text-sm font-mono placeholder:text-muted-foreground focus:outline-none focus:border-foreground transition-colors"
              />
              <button
                type="submit"
                class="w-full bg-link text-white font-mono text-[0.6rem] tracking-widest uppercase px-8 py-3 hover:opacity-75 transition-opacity cursor-pointer font-bold"
              >
                Assinar gratuitamente
              </button>
            </form>
            <p id="subscribe-msg" class="mt-3 text-sm font-mono text-center hidden"></p>
            <p class="mt-4 text-center text-[0.65rem] text-muted-foreground font-mono">
              Gratuito, sem spam. Cancele quando quiser.
            </p>
          </div>

          <!-- Estado de sucesso -->
          <div id="subscribe-success" class="hidden text-center py-4">
            <div class="mb-4">
              <svg class="mx-auto w-12 h-12 text-foreground animate-[checkmark_0.4s_ease-in-out]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path class="[stroke-dasharray:24] [stroke-dashoffset:24] animate-[dash_0.5s_0.2s_ease-out_forwards]" d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <p class="font-serif text-xl font-bold mb-2">Inscrito com sucesso!</p>
            <p class="text-sm text-muted-foreground">Ate segunda-feira no seu inbox.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="border-t border-foreground/10 py-6 text-center font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground">
      &copy; {new Date().getFullYear()} {SITE_NAME}. Todos os direitos reservados.
    </footer>

    <!-- Toggle de tema fixo -->
    <button
      id="theme-toggle"
      aria-label="Alternar tema claro/escuro"
      class="fixed bottom-6 right-6 z-50 font-mono text-[0.6rem] tracking-widest uppercase border border-border bg-background text-muted-foreground hover:text-foreground hover:border-foreground px-3 py-2 transition-colors cursor-pointer select-none"
    >
      <span id="theme-icon" aria-hidden="true"></span>
    </button>

    <script>
      // ── Modal de assinatura ──────────────────────────────────────────────
      ;(function () {
        const modal = document.getElementById('subscribe-modal')
        const overlay = document.getElementById('subscribe-overlay')
        const card = document.getElementById('subscribe-card')
        const openBtns = document.querySelectorAll('[data-subscribe-open], #subscribe-open-btn')
        const closeBtn = document.getElementById('subscribe-close-btn')
        const form = document.getElementById('subscribe-form') as HTMLFormElement | null
        const msg = document.getElementById('subscribe-msg')
        const formContent = document.getElementById('subscribe-form-content')
        const successContent = document.getElementById('subscribe-success')

        const EMAIL_RE = /^[a-z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)*\.[a-z]{2,}$/

        function openModal() {
          if (!modal || !overlay || !card) return
          modal.classList.remove('hidden')
          document.body.classList.add('overflow-hidden')
          requestAnimationFrame(() => {
            overlay.classList.remove('opacity-0')
            overlay.classList.add('opacity-100')
            card.classList.remove('translate-y-4', 'opacity-0')
            card.classList.add('translate-y-0', 'opacity-100')
          })
        }

        function closeModal() {
          if (!modal || !overlay || !card) return
          overlay.classList.remove('opacity-100')
          overlay.classList.add('opacity-0')
          card.classList.remove('translate-y-0', 'opacity-100')
          card.classList.add('translate-y-4', 'opacity-0')
          setTimeout(() => {
            modal.classList.add('hidden')
            document.body.classList.remove('overflow-hidden')
          }, 300)
        }

        openBtns.forEach(btn => btn.addEventListener('click', openModal))
        closeBtn?.addEventListener('click', closeModal)
        overlay?.addEventListener('click', closeModal)
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) closeModal()
        })

        form?.addEventListener('submit', async (e) => {
          e.preventDefault()
          const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim().toLowerCase()

          if (!email || !EMAIL_RE.test(email)) {
            if (msg) {
              msg.classList.remove('hidden')
              msg.textContent = 'Digite um email valido.'
              msg.className = 'mt-3 text-sm font-mono text-center text-destructive'
            }
            return
          }

          try {
            const res = await fetch('/api/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email }),
            })
            const data = await res.json()

            if (res.ok) {
              formContent?.classList.add('hidden')
              successContent?.classList.remove('hidden')
            } else {
              if (msg) {
                msg.classList.remove('hidden')
                msg.textContent = data.error ?? 'Erro ao inscrever. Tente novamente.'
                msg.className = 'mt-3 text-sm font-mono text-center text-destructive'
              }
            }
          } catch {
            if (msg) {
              msg.classList.remove('hidden')
              msg.textContent = 'Erro de conexao. Tente novamente.'
              msg.className = 'mt-3 text-sm font-mono text-center text-destructive'
            }
          }
        })
      })()
    </script>

    <script>
      // Deve corresponder a THEME_STORAGE_KEY em lib/config.ts
      const html = document.documentElement
      const icon = document.getElementById('theme-icon')

      function updateIcon() {
        if (icon) icon.textContent = html.classList.contains('dark') ? '○ CLARO' : '● ESCURO'
      }

      updateIcon()

      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const nowDark = html.classList.toggle('dark')
        localStorage.setItem('devpulse-theme', nowDark ? 'dark' : 'light')
        updateIcon()
      })
    </script>
  </body>
</html>
