---
import '@/styles/globals.css'
import { ClientRouter } from 'astro:transitions'
import AnnouncementBanner from '@/components/AnnouncementBanner.astro'
import SiteNav from '@/components/SiteNav.astro'
import { SITE_NAME, SITE_DESCRIPTION, normalizePublicSiteUrl } from '@/lib/config'
import { readEnv } from '@/lib/env'
import { getActiveSiteAnnouncement } from '@/lib/site-announcements'
import { supabase } from '@/lib/supabase'

interface Props {
  title?: string
  description?: string
  ogTitle?: string
  canonicalUrl?: string
  robots?: string
}

const {
  title = SITE_NAME,
  description = SITE_DESCRIPTION,
  ogTitle,
  canonicalUrl,
  robots,
} = Astro.props

const socialTitle = ogTitle ?? title
const canonicalHref = new URL(canonicalUrl ?? Astro.url.pathname, Astro.url).href
const siteUrl = normalizePublicSiteUrl(readEnv('SITE_URL'))
const topAnnouncement = await getActiveSiteAnnouncement(supabase)
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalHref} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} RSS`} href={`${siteUrl}/rss.xml`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // Deve corresponder a THEME_STORAGE_KEY em lib/config.ts
      ;(function () {
        document.documentElement.dataset.routeReady = 'true'
        const saved = localStorage.getItem('devpulse-theme')
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        const isDark = saved === 'dark' || (!saved && prefersDark)
        document.documentElement.classList.toggle('dark', isDark)
        document.documentElement.style.colorScheme = isDark ? 'dark' : 'light'
      })()
    </script>
  </head>
  <body class="antialiased">
    <div id="page-shell">
      <a href="#main-content" class="skip-link">Pular para o conteúdo</a>

      <SiteNav />

      {topAnnouncement && (
        <div data-announcement-slot class="mx-auto max-w-6xl px-6 pt-4 sm:px-10">
          <AnnouncementBanner announcement={topAnnouncement} compact />
        </div>
      )}

      <main id="main-content" tabindex="-1" transition:animate="fade">
        <slot />
      </main>

      <footer class="border-t border-foreground/10 py-6 text-center font-mono text-[0.6rem] tracking-widest uppercase text-muted-foreground">
        &copy; {new Date().getFullYear()} {SITE_NAME}. Todos os direitos reservados.
      </footer>
    </div>

    <div id="subscribe-modal" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <div id="subscribe-overlay" class="absolute inset-0 bg-black/60 opacity-0 backdrop-blur-sm transition-opacity duration-300"></div>
      <div class="flex min-h-full items-center justify-center p-4">
        <div id="subscribe-card" class="relative w-full max-w-md translate-y-4 border-2 border-foreground/20 bg-background p-8 opacity-0 transition-all duration-300 sm:p-10">
          <button id="subscribe-close-btn" class="absolute right-4 top-4 cursor-pointer font-mono text-xs text-muted-foreground transition-colors hover:text-foreground" aria-label="Fechar">
            &times;
          </button>

          <div id="subscribe-form-content">
            <div class="mb-6 text-center">
              <div class="mb-4 border-b-2 border-double border-foreground/30 pb-3">
                <p id="modal-title" class="font-serif text-2xl font-black uppercase tracking-tight sm:text-3xl">
                  {SITE_NAME}
                </p>
              </div>
              <p class="text-sm leading-relaxed text-foreground/70">
                Receba toda segunda-feira uma curadoria dos melhores artigos, ferramentas e tendencias dev, traduzida e resumida em portugues.
              </p>
            </div>

            <form id="subscribe-form" class="space-y-3" data-astro-reload>
              <label class="sr-only" aria-hidden="true">
                Não preencha este campo
                <input
                  type="text"
                  name="website"
                  tabindex="-1"
                  autocomplete="off"
                  class="sr-only"
                />
              </label>
              <input
                type="email"
                name="email"
                placeholder="seu@email.com"
                required
                class="w-full border-2 border-foreground/20 bg-background px-4 py-2.5 text-sm font-mono placeholder:text-muted-foreground transition-colors focus:border-foreground focus:outline-none"
              />
              <button
                type="submit"
                data-subscribe-submit
                class="w-full bg-link px-8 py-2.5 font-mono text-[0.58rem] font-bold uppercase tracking-widest text-white transition-opacity hover:opacity-75"
              >
                Assinar gratuitamente
              </button>
            </form>
            <p id="subscribe-msg" class="mt-3 hidden text-center text-sm font-mono" aria-live="polite" role="status"></p>
            <p class="mt-4 text-center font-mono text-[0.65rem] text-muted-foreground">
              Gratuito, sem spam. Cancele quando quiser.
            </p>
          </div>

          <div id="subscribe-success" class="hidden py-4 text-center">
            <div class="mb-4">
              <svg class="mx-auto h-12 w-12 animate-[checkmark_0.4s_ease-in-out] text-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path class="[stroke-dasharray:24] [stroke-dashoffset:24] animate-[dash_0.5s_0.2s_ease-out_forwards]" d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <p class="mb-2 font-serif text-xl font-bold">Inscrito com sucesso!</p>
            <p class="text-sm text-muted-foreground">Ate segunda-feira no seu inbox.</p>
          </div>
        </div>
      </div>
    </div>

    <script>
      import '@/scripts/site-shell'
      import '@/scripts/article-pagination'
    </script>
  </body>
</html>
